{
  "ConnectionStrings": {
    // 本番環境では環境変数 ConnectionStrings__PhycockConnection で上書きすること
    "PhycockConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Smtp": {
    // 本番環境向けの設定例（実際の値は appsettings.Production.json や環境変数で上書きする）
    // Gmail の場合:    Host=smtp.gmail.com, Port=587, EnableSsl=true
    // SendGrid の場合: Host=smtp.sendgrid.net, Port=587, EnableSsl=true, UserName=apikey
    // 社内SMTPの場合:  Host=社内SMTPサーバー, Port=25, EnableSsl=false, 認証なし
    "Host": "smtp.example.com",
    "Port": "25",
    "EnableSsl": "true",
    "UserName": "",
    "Password": "",
    "Timeout": "30000"
  },
  "Mail": {
    "From": "noreply@example.com",
    "FromName": "Phycock",
    "AdminAddress": ""
  },
  "AppSettings": {
    "BaseFilePath": "~/Uploads/",
    "SampleFilePath": "~/Uploads/Sample/{0}/",
    "ExcelTempFilePath": "~/Templates/Excel/",
    "PDFTempFilePath": "~/Templates/PDF/"
  }
}
