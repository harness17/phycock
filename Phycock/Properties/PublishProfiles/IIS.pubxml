<?xml version="1.0" encoding="utf-8"?>
<!--
  発行プロファイル: IIS (ファイルシステム)
  発行先: C:\inetpub\wwwroot\Phycock
  発行コマンド: dotnet publish Phycock/Phycock.csproj -p:PublishProfile=IIS
  ※ 発行前後に IIS アプリプール "Phycock" を自動停止/起動する
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net10.0</TargetFramework>
    <PublishDir>C:\inetpub\wwwroot\Phycock</PublishDir>
    <SelfContained>false</SelfContained>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <DeleteExistingFiles>true</DeleteExistingFiles>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <!-- 操作対象の IIS アプリプール名 -->
    <IISAppPoolName>Phycock</IISAppPoolName>
    <SiteUrlToLaunchAfterPublish />
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>a1b2c3d4-e5f6-7890-abcd-ef1234567890</ProjectGuid>
    <publishUrl>C:\inetpub\wwwroot\Phycock</publishUrl>
  </PropertyGroup>
  <!-- 発行前: アプリプールを停止してDLLロックを解除 -->
  <Target Name="StopAppPool" BeforeTargets="BeforePublish">
    <Exec Command="powershell -NonInteractive -Command &quot;Import-Module WebAdministration; $pool = Get-WebConfigurationProperty -Filter '/system.applicationHost/applicationPools/add[@name=''$(IISAppPoolName)'']' -Name 'state' -PSPath 'IIS:\' -ErrorAction SilentlyContinue; if ($pool -ne $null -and $pool.Value -ne 'Stopped') { Stop-WebAppPool -Name '$(IISAppPoolName)'; Start-Sleep -Seconds 2 }&quot;" ContinueOnError="true" />
  </Target>
  <!-- 発行後: アプリプールを再起動 -->
  <Target Name="StartAppPool" AfterTargets="Publish">
    <Exec Command="powershell -NonInteractive -Command &quot;Import-Module WebAdministration; Start-WebAppPool -Name '$(IISAppPoolName)'&quot;" ContinueOnError="true" />
  </Target>
</Project>
