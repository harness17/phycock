@model List<Phycock.Models.SleepRecordListViewModel>
@{
    ViewData["Title"] = "睡眠記録";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">睡眠記録</h1>
    <a asp-action="Create" asp-route-recordDate="@ViewBag.FilterDate" class="btn btn-primary"><i class="fas fa-plus me-1"></i>追加</a>
</div>

<div id="sleepCalendar" class="record-calendar record-calendar--sleep"></div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        const sleepRecordUrls = {
            events: '@Url.Action("GetEvents", "SleepRecord")',
            create: '@Url.Action("Create", "SleepRecord")',
            editBase: '@Url.Action("Edit", "SleepRecord")'
        };

        document.addEventListener('DOMContentLoaded', function () {
            const calendar = new FullCalendar.Calendar(document.getElementById('sleepCalendar'), {
                initialView: 'dayGridMonth',
                locale: 'ja',
                height: 'auto',
                dayMaxEvents: false,
                selectable: true,
                displayEventTime: true,
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,listMonth'
                },
                buttonText: {
                    today: '今日',
                    month: '月',
                    list: '一覧'
                },
                events: sleepRecordUrls.events,
                dateClick: function (info) {
                    window.location.href = sleepRecordUrls.create + '?recordDate=' + encodeURIComponent(info.dateStr);
                },
                eventClick: function (info) {
                    window.location.href = sleepRecordUrls.editBase + '/' + info.event.id;
                }
            });
            calendar.render();
        });
    </script>
}
