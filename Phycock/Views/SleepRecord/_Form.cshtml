@model Phycock.Models.SleepRecordFormViewModel

<form method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="UserId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="RecordDate" class="form-label"></label>
            <input asp-for="RecordDate" type="date" class="form-control" />
            <span asp-validation-for="RecordDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SleepType" class="form-label"></label>
            <select asp-for="SleepType" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.SleepType>()" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="StartTime" class="form-label"></label>
            <input asp-for="StartTime" type="time" value="@(Model.StartTime?.ToString("HH:mm") ?? "")" class="form-control time-focus-input" step="60" data-next-time-input="#EndTime" />
            <span asp-validation-for="StartTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="EndTime" class="form-label"></label>
            <input asp-for="EndTime" type="time" value="@(Model.EndTime?.ToString("HH:mm") ?? "")" class="form-control time-focus-input" step="60" />
            <span asp-validation-for="EndTime" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Memo" class="form-label"></label>
            <textarea asp-for="Memo" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Memo" class="text-danger"></span>
        </div>
    </div>
    <div class="mt-4 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">保存</button>
        <a asp-action="Index" class="btn btn-outline-secondary">戻る</a>
        @if (Model.Id != 0)
        {
            <button type="submit" formaction="@Url.Action("Delete", "SleepRecord")"
                    formmethod="post" formnovalidate class="btn btn-outline-danger ms-auto cancel"
                    onclick="return confirm('この睡眠記録を削除します。よろしいですか？');">削除</button>
        }
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        window.PhycockTimeInput?.init(document);
    });
</script>
