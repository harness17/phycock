@model Phycock.Models.SleepRecordFormViewModel

<form method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="UserId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="RecordDate" class="form-label"></label>
            <input asp-for="RecordDate" type="date" class="form-control" />
            <span asp-validation-for="RecordDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="SleepType" class="form-label"></label>
            <select asp-for="SleepType" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.SleepType>()" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="StartTime" class="form-label"></label>
            <input asp-for="StartTime" type="text" value="@(Model.StartTime?.ToString("HH:mm") ?? "")" class="form-control sleep-time-input" inputmode="numeric" maxlength="5" placeholder="22:00" autocomplete="off" data-next-time-input="#EndTime" />
            <span asp-validation-for="StartTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="EndTime" class="form-label"></label>
            <input asp-for="EndTime" type="text" value="@(Model.EndTime?.ToString("HH:mm") ?? "")" class="form-control sleep-time-input" inputmode="numeric" maxlength="5" placeholder="06:00" autocomplete="off" />
            <span asp-validation-for="EndTime" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Memo" class="form-label"></label>
            <textarea asp-for="Memo" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Memo" class="text-danger"></span>
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">保存</button>
        <a asp-action="Index" class="btn btn-outline-secondary">戻る</a>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.sleep-time-input').forEach(function (input) {
            input.addEventListener('input', function () {
                const normalized = normalizeSleepTime(input.value);
                if (normalized) {
                    input.value = normalized;
                    const nextSelector = input.getAttribute('data-next-time-input');
                    if (nextSelector) {
                        const nextInput = document.querySelector(nextSelector);
                        if (nextInput) nextInput.focus();
                    }
                }
            });
        });

        function normalizeSleepTime(value) {
            const digits = value.replace(/\D/g, '');
            if (digits.length === 4) {
                const hour = Number(digits.slice(0, 2));
                const minute = Number(digits.slice(2, 4));
                if (hour <= 23 && minute <= 59) {
                    return digits.slice(0, 2) + ':' + digits.slice(2, 4);
                }
            }

            if (/^([01]\d|2[0-3]):[0-5]\d$/.test(value)) return value;

            return '';
        }
    });
</script>
