@model Phycock.Models.DashboardViewModel
@using Phycock.Common
@{
    ViewData["Title"] = "ホーム";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">ダッシュボード</h1>
        <p class="text-muted mb-0">今日の予定と直近の体調を確認できます。</p>
    </div>
    <div class="btn-group">
        <a asp-controller="HealthRecord" asp-action="Create" class="btn btn-primary"><i class="fas fa-notes-medical me-1"></i>体調記録</a>
        <a asp-controller="SleepRecord" asp-action="Create" class="btn btn-outline-primary"><i class="fas fa-bed me-1"></i>睡眠記録</a>
    </div>
</div>

@if (Model.IsUnavailable)
{
    <div class="alert alert-warning" role="alert">
        <i class="fas fa-exclamation-triangle me-1"></i>データの取得に失敗しました。しばらく後に再読み込みしてください。
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-3">今日のチェックリスト</h5>
            <ul class="list-unstyled mb-0">
                <li class="mb-1">
                    @(Model.TodayHealthRecords.Any() ? "✅" : "⬜") 体調記録
                </li>
                <li class="mb-1">
                    @(Model.HasSleepRecord ? "✅" : "⬜") 睡眠記録
                </li>
                <li class="mb-1">
                    @if (Model.TodayScheduleEntries.Any())
                    {
                        <text>✅ 通所予定</text>
                    }
                    else
                    {
                        <span class="text-muted">🔘 通所予定（休日）</span>
                    }
                </li>
            </ul>
            @if (Model.LatestCondition.HasValue)
            {
                <div class="mt-2 small text-muted">
                    直近の体調: @Model.LatestCondition.Value.GetDisplayName()
                    @if (Model.LatestFeeling.HasValue)
                    {
                        <text> / 気分: @Model.LatestFeeling.Value.GetDisplayName()</text>
                    }
                </div>
            }
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-lg-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">今日の通所予定</h5>
                @if (Model.TodayScheduleEntries.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.TodayScheduleEntries)
                        {
                            <li class="list-group-item px-0">
                                <div class="fw-semibold">@item.Session.GetDisplayName() / @(item.IsAtHome ? "在宅" : "通所")</div>
                                <div class="small text-muted">@item.ActivityType.GetDisplayName() @item.StartTime - @item.EndTime</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">今日の通所予定はありません。</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">今日の体調</h5>
                @if (Model.TodayHealthRecords.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var record in Model.TodayHealthRecords)
                        {
                            <li class="list-group-item px-0">
                                <div class="fw-semibold">@record.TimingLabel</div>
                                <div class="small">体調: @record.Condition.GetDisplayName() / 気分: @record.Feeling.GetDisplayName()</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">今日の体調記録はまだありません。</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">直近7日サマリー</h5>
                <dl class="row mb-0">
                    <dt class="col-6">体調平均</dt>
                    <dd class="col-6">@(Model.WeeklySummary.AverageCondition?.ToString("0.0") ?? "-")</dd>
                    <dt class="col-6">気分平均</dt>
                    <dd class="col-6">@(Model.WeeklySummary.AverageFeeling?.ToString("0.0") ?? "-")</dd>
                    <dt class="col-6">睡眠合計</dt>
                    <dd class="col-6">@Model.WeeklySummary.TotalSleepDuration.TotalHours.ToString("0.0") 時間</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-calendar-alt me-2"></i>通所スケジュール</h5>
                <p class="card-text">通所・外出予定と実績を管理できます。</p>
                <a asp-controller="ScheduleEntry" asp-action="Index" class="btn btn-primary">カレンダーへ</a>
            </div>
        </div>
    </div>
    @* ポイント: Admin ロールのみ表示する管理機能カード *@
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-6 mb-3">
            <div class="card h-100 border-warning">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-users-cog me-2"></i>ユーザー・ロール管理</h5>
                    <p class="card-text">ユーザーの一覧・編集・無効化、ロールの変更ができます。（Admin限定）</p>
                    <a asp-controller="UserManagement" asp-action="Index" class="btn btn-warning">一覧へ</a>
                </div>
            </div>
        </div>
    }
</div>
