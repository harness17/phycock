@model UserManagementResetPasswordViewModel
@{
    ViewData["Title"] = "パスワード変更";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-controller="UserManagement" asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            @* ポイント: Id を hidden で保持して対象ユーザーを特定する *@
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            @* ポイント: 対象ユーザーの確認用に表示するのみ。ここでは変更しない *@
            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <p class="form-control-plaintext">@Model.UserName</p>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" type="password" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">パスワードを変更する</button>
                <a asp-action="Index" asp-route-returnList="true" class="btn btn-secondary ms-2">一覧に戻る</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
