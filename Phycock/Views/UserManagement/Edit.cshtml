@model UserManagementEditViewModel
@{
    ViewData["Title"] = "ユーザー編集";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-controller="UserManagement" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            @* ポイント: Id を hidden で保持することで更新対象ユーザーを特定する *@
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="EmailConfirmed" class="form-check-input" />
                    <label asp-for="EmailConfirmed" class="form-check-label"></label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">ロール</label>
                @*
                    ポイント: チェックボックス複数選択は name="RoleNames" を各チェックボックスに指定する
                    MVC バインディングが同名の値を List<string> にまとめてくれる
                *@
                @foreach (var role in Model.AvailableRoles)
                {
                    @* ポイント: 初期 Admin ユーザーの Admin ロールは変更不可（disabled + hidden で送信値も保持） *@
                    var isProtected = Model.Id == Const.SystemAdminUserId && role.Value == "Admin";
                    var isChecked   = Model.RoleNames.Contains(role.Value ?? "");
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="RoleNames"
                               id="role_@role.Value"
                               value="@role.Value"
                               @(isChecked ? "checked" : "")
                               @(isProtected ? "disabled" : "") />
                        @* disabled なチェックボックスはフォーム送信に含まれないため hidden で補完する *@
                        @if (isProtected)
                        {
                            <input type="hidden" name="RoleNames" value="@role.Value" />
                        }
                        <label class="form-check-label" for="role_@role.Value">
                            @role.Text
                            @if (isProtected)
                            {
                                <span class="text-muted small ms-1">（変更不可）</span>
                            }
                        </label>
                    </div>
                }
            </div>

            <div>
                <button type="submit" class="btn btn-primary">更新</button>
                <a asp-action="Index" asp-route-returnList="true" class="btn btn-secondary ms-2">一覧に戻る</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
