@model UserManagementViewModel
@{
    var summary = Model.RowData.Summary;
    var currentPage = summary?.CurrentPage ?? 1;
    var totalRecords = summary?.TotalRecords ?? 0;
    var recoedNumber = Model.Cond.Pager.recoedNumber > 0 ? Model.Cond.Pager.recoedNumber : 10;
    // ポイント: Math.Ceiling で切り上げて総ページ数を算出する
    var totalPage = totalRecords > 0 ? (int)Math.Ceiling((double)totalRecords / recoedNumber) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>全 <strong>@totalRecords</strong> 件</div>
    <div class="d-flex align-items-center">
        <span class="me-2">表示件数：</span>
        <select onchange="funcRecordNumber(value)" class="form-select form-select-sm" style="width:auto;">
            @foreach (var item in Model.RecoedNumberList)
            {
                <option value="@item.Value" selected="@(item.Value == Model.RecordNum.ToString())">@item.Text</option>
            }
        </select>
    </div>
</div>

@if (Model.RowData.rows == null || !Model.RowData.rows.Any())
{
    <div class="alert alert-info">データなし</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('UserName')" class="text-white text-decoration-none">
                            ユーザー名
                            @if (Model.Sort == "UserName")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Email')" class="text-white text-decoration-none">
                            メールアドレス
                            @if (Model.Sort == "Email")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>ロール</th>
                    @* ポイント: ロック状態は LockoutEnd と現在時刻を比較して判定する *@
                    <th>ロック状態</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RowData.rows)
                {
                    <tr>
                        <td>@row.UserName</td>
                        <td>@row.Email</td>
                        <td>
                            @foreach (var role in row.Roles)
                            {
                                <span class="badge bg-primary me-1">@role</span>
                            }
                        </td>
                        <td>
                            @if (row.LockoutEnd.HasValue && row.LockoutEnd > DateTimeOffset.UtcNow)
                            {
                                <span class="badge bg-danger">ロック中</span>
                            }
                            else
                            {
                                <span class="badge bg-success">正常</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-sm btn-primary">編集</a>
                            @* ポイント: 初期 Admin ユーザーは削除禁止のためボタンを無効化する *@
                            @if (row.Id == Const.SystemAdminUserId)
                            {
                                <button type="button" class="btn btn-sm btn-danger" disabled title="初期管理者ユーザーは削除できません">削除</button>
                            }
                            else
                            {
                                <a asp-action="Delete" asp-route-id="@row.Id" class="btn btn-sm btn-danger">削除</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage - 1))">前へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">前へ</span>
                </li>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPage, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@i)">@i</a>
                </li>
            }

            @if (currentPage < totalPage)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage + 1))">次へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">次へ</span>
                </li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted">
        @currentPage / @totalPage ページ
    </div>
}
