@model UserManagementViewModel
@{
    ViewData["Title"] = "ユーザー・ロール管理";
}

<h2>@ViewData["Title"]</h2>

@*
    ポイント: 検索フォームの hidden フィールドで Page / Sort / SortDir / RecordNum / PageRead を管理する
    JavaScript がこれらの値を書き換えてから submit することで、ページング・ソート・件数変更に対応する
*@
<form id="SearchForm" asp-controller="UserManagement" asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Page" type="hidden" />
    <input asp-for="Sort" type="hidden" />
    <input asp-for="SortDir" type="hidden" />
    <input asp-for="RecordNum" type="hidden" />
    <input asp-for="PageRead" type="hidden" />

    <div class="card mb-3">
        <div class="card-header">検索条件</div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-4">
                    <label asp-for="Cond.UserName" class="form-label"></label>
                    <input asp-for="Cond.UserName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Cond.Email" class="form-label"></label>
                    <input asp-for="Cond.Email" class="form-control" />
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="button" class="btn btn-primary" onclick="funcSearch()">
                <i class="fas fa-search me-1"></i>検索
            </button>
            <button type="button" class="btn btn-secondary ms-1" onclick="funcClear()">
                <i class="fas fa-times me-1"></i>クリア
            </button>
        </div>
    </div>
</form>

@*
    ポイント: 検索結果エリアを div で囲み、Ajax 成功時にパーシャルビューで差し替える
    初期表示はサーバー側レンダリング、以降は Ajax で部分更新する
*@
<div id="SearchResult">
    @await Html.PartialAsync("_IndexPartial", Model)
</div>

@section Scripts {
    <script>
        function funcSearch() {
            $('#Page').val(1);
            $('#PageRead').val('Resarch');
            submitSearch();
        }

        function funcClear() {
            window.location.href = '@Url.Action("Index")';
        }

        function funcSort(sortColumn) {
            var currentSort = $('#Sort').val();
            var currentDir = $('#SortDir').val();
            if (currentSort === sortColumn) {
                $('#SortDir').val(currentDir === 'ASC' ? 'DESC' : 'ASC');
            } else {
                $('#Sort').val(sortColumn);
                $('#SortDir').val('ASC');
            }
            $('#Page').val(1);
            $('#PageRead').val('Sorting');
            submitSearch();
        }

        function funcRecordNumber(val) {
            $('#RecordNum').val(val);
            $('#Page').val(1);
            $('#PageRead').val('ChangeRecordNum');
            submitSearch();
        }

        function funcPage(page) {
            $('#Page').val(page);
            $('#PageRead').val('Paging');
            submitSearch();
        }

        function submitSearch() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index")',
                data: $('#SearchForm').serialize(),
                success: function (result) {
                    $('#SearchResult').html(result);
                },
                error: function () {
                    alert('検索中にエラーが発生しました。');
                }
            });
        }
    </script>
}
