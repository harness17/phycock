@using Microsoft.AspNetCore.Identity
@using Phycock.Entity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-white">@UserManager.GetUserName(User)</span>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-controller="Manage" asp-action="Index">アカウント管理</a>
    </li>
    <li class="nav-item">
        <form asp-controller="Account" asp-action="LogOff" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link nav-link text-white">ログアウト</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-controller="Account" asp-action="Register">新規登録</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-controller="Account" asp-action="Login">ログイン</a>
    </li>
}
