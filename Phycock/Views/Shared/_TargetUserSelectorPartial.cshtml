@inject Phycock.Service.UserManagementService UserManagementService
@{
    var users = await UserManagementService.GetMemberListAsync();
    var selectedUserId = await UserManagementService.GetSelectedMemberUserIdAsync();
    // PathBase を含めないとサブアプリ配置（/Phycock 配下など）で Redirect 先が 404 になる
    var returnUrl = Context.Request.PathBase + Context.Request.Path + Context.Request.QueryString;
}

@if (User.IsInRole("Admin") && users.Any())
{
    <li class="nav-item me-xl-2 my-2 my-xl-0">
        <form asp-controller="TargetUser" asp-action="Select" method="post" class="d-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <label for="globalTargetUserId" class="text-white small mb-0 text-nowrap">対象利用者</label>
            <select id="globalTargetUserId" name="targetUserId" class="form-select form-select-sm" onchange="this.form.submit()">
                @foreach (var user in users)
                {
                    if (user.Value == selectedUserId)
                    {
                        <option value="@user.Value" selected>@user.Text</option>
                    }
                    else
                    {
                        <option value="@user.Value">@user.Text</option>
                    }
                }
            </select>
        </form>
    </li>
}
