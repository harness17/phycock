@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var isPrint = (ViewData["Print"] as bool?) == true;
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* ポイント: CSRF トークンを meta タグに埋め込み、Ajax POST 時に X-CSRF-TOKEN ヘッダーで送信する *@
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <title>@ViewData["Title"] - Phycock</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/phycock-mark.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100@(isPrint ? " print-mode" : "")">
    @if (!isPrint)
    {
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand d-inline-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img class="navbar-brand-logo" src="~/images/phycock-mark.png" asp-append-version="true" alt="" width="32" height="32" />
                    <span>Phycock</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">ホーム</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Calendar" asp-action="Index">カレンダー</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="HealthRecord" asp-action="Index">体調記録</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="SleepRecord" asp-action="Index">睡眠記録</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="ScheduleEntry" asp-action="Index">通所スケジュール</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Statistics" asp-action="Index">統計</a>
                        </li>
                        @* ポイント: Admin ロールのみ表示する管理メニュー *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="UserManagement" asp-action="Index">ユーザー管理</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            @await Html.PartialAsync("_TargetUserSelectorPartial")
                        }
                        @* ポイント: 認証済みユーザーのみ通知ベルを表示する *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @await Html.PartialAsync("_NotificationPartial")
                        }
                        @await Html.PartialAsync("_LoginPartial")
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    }

    <div class="@(isPrint ? "container-fluid" : "container") flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (!isPrint)
    {
    <footer class="border-top text-muted mt-4 py-3">
        <div class="container">
            &copy; 2026 - Phycock
        </div>
    </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* ポイント: _LayoutModalPartial は jQuery を使用するため jQuery 読み込み後に配置する *@
    @await Html.PartialAsync("_LayoutModalPartial")

    @await RenderSectionAsync("Scripts", required: false)

    @* ポイント: 通知ポーリング JS は jQuery 読み込み後に記述する必要があるためここに配置 *@
    @* ポイント: print=1 のときは通知ポーリング・CSRF 設定をスキップ（PDF生成時の余計な通信を避ける） *@
    @if (User.Identity?.IsAuthenticated == true && !isPrint)
    {
        <script>
            // ─── Ajax 共通設定：CSRF トークンをすべての POST リクエストに自動付加 ──
            // ポイント: $.ajaxSetup で一括設定することで個別リクエストへの追加が不要になる
            $.ajaxSetup({
                beforeSend: function (xhr, settings) {
                    if (settings.type === 'POST' || settings.type === 'post') {
                        xhr.setRequestHeader('X-CSRF-TOKEN', $('meta[name="csrf-token"]').attr('content'));
                    }
                }
            });

            // ─── 通知ポーリング ──────────────────────────────────────────────
            // ポイント: ダッシュボードと同じ Ajax ポーリング方式（10秒間隔）
            //           ベルアイコンのバッジ表示を定期的に更新する

            function loadNotificationCount() {
                $.get('/Notification/GetUnreadCount', function (data) {
                    if (data.count > 0) {
                        $('#notificationBadge').text(data.count).show();
                    } else {
                        $('#notificationBadge').hide();
                    }
                });
            }

            function loadNotificationList() {
                $.get('/Notification/GetRecent', function (items) {
                    if (!items || items.length === 0) {
                        $('#notificationList').html(
                            '<div class="px-3 py-3 text-muted small text-center">通知はありません</div>'
                        );
                        return;
                    }

                    const $list = $('#notificationList').empty();
                    items.forEach(function (item) {
                        // ポイント: 未読は背景色を変えて強調表示する
                        const bgClass = item.isRead ? '' : 'bg-light';
                        const fontClass = item.isRead ? 'text-muted' : 'fw-semibold';
                        // ポイント: XSS 対策 — message・createDate は .text() で設定し HTML として解釈させない
                        //           ユーザー入力のタイトルが通知メッセージに含まれるため innerHTML への直接展開は禁止
                        const $a = $('<a>')
                            .addClass('dropdown-item notification-item py-2 border-bottom ' + bgClass)
                            .attr({ href: '#', 'data-id': item.id, 'data-url': item.relatedUrl || '' });
                        $('<div>').addClass('small ' + fontClass).text(item.message).appendTo($a);
                        $('<div>').addClass('text-muted').css('font-size', '0.72rem').text(item.createDate).appendTo($a);
                        $list.append($a);
                    });
                }).fail(function () {
                    $('#notificationList').html(
                        '<div class="px-3 py-2 text-danger small">取得に失敗しました</div>'
                    );
                });
            }

            // ─── ドロップダウン開時に一覧を再取得 ───────────────────────────
            $('#notificationBell').on('show.bs.dropdown', function () {
                loadNotificationList();
            });

            // ─── 通知クリック → 既読 + 遷移 ────────────────────────────────
            $(document).on('click', '.notification-item', function (e) {
                e.preventDefault();
                const id = $(this).data('id');
                const url = $(this).data('url');
                $.ajax({
                    type: 'POST',
                    url: '/Notification/MarkAsRead',
                    contentType: 'application/json',
                    data: JSON.stringify({ id: id }),
                    success: function () {
                        loadNotificationCount();
                        if (url) { window.location.href = url; }
                        else { loadNotificationList(); }
                    }
                });
            });

            // ─── すべて既読ボタン ────────────────────────────────────────────
            $('#markAllReadBtn').on('click', function (e) {
                e.stopPropagation();
                $.post('/Notification/MarkAllAsRead', function () {
                    loadNotificationCount();
                    loadNotificationList();
                });
            });

            // ─── 初回ロード + 10秒ポーリング ────────────────────────────────
            loadNotificationCount();
            setInterval(loadNotificationCount, 10000);
        </script>
    }
</body>
</html>
