@model List<Phycock.Models.HealthRecordListViewModel>
@{
    ViewData["Title"] = "体調記録";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">体調記録</h1>
    <a asp-action="Create" asp-route-recordDate="@ViewBag.FilterDate" class="btn btn-primary"><i class="fas fa-plus me-1"></i>追加</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-sm-4 col-md-3">
        <label for="filterDate" class="form-label">日付</label>
        <input id="filterDate" name="filterDate" type="date" value="@ViewBag.FilterDate" class="form-control" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">表示</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>日付</th>
                @if (ViewBag.IsAdmin == true)
                {
                    <th>ユーザーID</th>
                }
                <th>タイミング</th>
                <th>体調</th>
                <th>気分</th>
                <th>症状</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RecordDate.ToString("yyyy/MM/dd")</td>
                @if (ViewBag.IsAdmin == true)
                {
                    <td>@item.UserId</td>
                }
                <td>@item.RecordTiming.GetDisplayName()</td>
                <td>@item.Condition.GetDisplayName()</td>
                <td>@item.Feeling.GetDisplayName()</td>
                <td>@item.Symptoms</td>
                <td class="text-end">
                    <button type="button" class="btn btn-sm btn-outline-secondary detail-btn" data-id="@item.Id">詳細</button>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">編集</a>
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">削除</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">体調記録詳細</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
            </div>
            <div class="modal-body" id="detailBody"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.detail-btn').on('click', function () {
            $.get('/HealthRecord/Detail/' + $(this).data('id'), function (item) {
                const symptoms = item.symptoms && item.symptoms.length ? item.symptoms.join('、') : '-';
                $('#detailBody').html(
                    '<dl class="row mb-0">' +
                    '<dt class="col-4">記録日</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">タイミング</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">体調</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">気分</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">症状</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">メモ</dt><dd class="col-8"></dd>' +
                    '</dl>');
                const dds = $('#detailBody dd');
                dds.eq(0).text(item.recordDate);
                dds.eq(1).text(item.recordTiming);
                dds.eq(2).text(item.condition);
                dds.eq(3).text(item.feeling);
                dds.eq(4).text(symptoms);
                dds.eq(5).text(item.memo || '-');
                new bootstrap.Modal(document.getElementById('detailModal')).show();
            });
        });
    </script>
}
