@model List<Phycock.Models.HealthRecordListViewModel>
@{
    ViewData["Title"] = "体調記録";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">体調記録</h1>
    <a asp-action="Create" asp-route-recordDate="@ViewBag.FilterDate" class="btn btn-primary"><i class="fas fa-plus me-1"></i>追加</a>
</div>

<div id="healthCalendar" class="record-calendar record-calendar--health"></div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">体調記録詳細</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
            </div>
            <div class="modal-body" id="detailBody"></div>
            <div class="modal-footer">
                <a id="editLink" href="#" class="btn btn-primary">編集</a>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">閉じる</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        const healthRecordUrls = {
            events: '@Url.Action("GetEvents", "HealthRecord")',
            detailBase: '@Url.Action("Detail", "HealthRecord")',
            editBase: '@Url.Action("Edit", "HealthRecord")',
            create: '@Url.Action("Create", "HealthRecord")'
        };

        function showHealthDetail(id) {
            $.get(healthRecordUrls.detailBase + '/' + id, function (item) {
                const symptoms = item.symptoms && item.symptoms.length ? item.symptoms.join('、') : '-';
                $('#detailBody').html(
                    '<dl class="row mb-0">' +
                    '<dt class="col-4">記録日</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">タイミング</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">体調</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">気分</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">症状</dt><dd class="col-8"></dd>' +
                    '<dt class="col-4">メモ</dt><dd class="col-8"></dd>' +
                    '</dl>');
                const dds = $('#detailBody dd');
                dds.eq(0).text(item.recordDate);
                dds.eq(1).text(item.recordTiming);
                dds.eq(2).text(item.condition);
                dds.eq(3).text(item.feeling);
                dds.eq(4).text(symptoms);
                dds.eq(5).text(item.memo || '-');
                $('#editLink').attr('href', healthRecordUrls.editBase + '/' + id);
                new bootstrap.Modal(document.getElementById('detailModal')).show();
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const calendar = new FullCalendar.Calendar(document.getElementById('healthCalendar'), {
                initialView: 'dayGridMonth',
                locale: 'ja',
                height: 'auto',
                dayMaxEvents: false,
                selectable: true,
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,listMonth'
                },
                buttonText: {
                    today: '今日',
                    month: '月',
                    list: '一覧'
                },
                events: healthRecordUrls.events,
                eventDisplay: 'block',
                eventOrder: 'sortOrder,start,title',
                eventContent: PhycockCalendar.renderRecordEvent,
                eventDidMount: PhycockCalendar.applyEventColors,
                dateClick: function (info) {
                    window.location.href = healthRecordUrls.create + '?recordDate=' + encodeURIComponent(info.dateStr);
                },
                eventClick: function (info) {
                    showHealthDetail(info.event.id);
                }
            });
            calendar.render();
        });
    </script>
}
