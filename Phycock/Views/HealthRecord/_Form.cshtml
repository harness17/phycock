@model Phycock.Models.HealthRecordFormViewModel

<form method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="UserId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="RecordDate" class="form-label"></label>
            <input asp-for="RecordDate" type="date" class="form-control" />
            <span asp-validation-for="RecordDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="RecordTiming" class="form-label"></label>
            <select asp-for="RecordTiming" class="form-select" data-health-record-timing-select>
                @foreach (var timing in Enum.GetValues<RecordTiming>())
                {
                    var disabled = Model.DisabledRecordTimings.Contains(timing);
                    var selected = Model.RecordTiming == timing;
                    if (selected)
                    {
                        <option value="@((int)timing)" disabled="@disabled" selected>@timing.GetDisplayName()</option>
                    }
                    else
                    {
                        <option value="@((int)timing)" disabled="@disabled">@timing.GetDisplayName()</option>
                    }
                }
            </select>
            <span asp-validation-for="RecordTiming" class="text-danger"></span>
        </div>
        <div class="col-md-4" data-health-record-custom-time-wrap>
            <label asp-for="RecordTime" class="form-label"></label>
            <input asp-for="RecordTime" type="time" class="form-control time-focus-input" step="60" data-health-record-custom-time />
            <span asp-validation-for="RecordTime" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="Condition" class="form-label"></label>
            <select asp-for="Condition" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.ConditionLevel>()" class="form-select"></select>
            <span asp-validation-for="Condition" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="Feeling" class="form-label"></label>
            <select asp-for="Feeling" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.FeelingLevel>()" class="form-select"></select>
            <span asp-validation-for="Feeling" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-label">症状</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var symptom in Enum.GetValues<SymptomType>().Where(x => x != SymptomType.None))
                {
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedSymptoms" value="@symptom" checked="@Model.SelectedSymptoms.Contains(symptom)" />
                        <span class="form-check-label">@symptom.GetDisplayName()</span>
                    </label>
                }
            </div>
        </div>
        <div class="col-12">
            <label asp-for="Memo" class="form-label"></label>
            <textarea asp-for="Memo" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Memo" class="text-danger"></span>
        </div>
    </div>
    <div class="mt-4 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">保存</button>
        <a asp-action="Index" class="btn btn-outline-secondary">戻る</a>
        @if (Model.Id != 0)
        {
            <button type="submit" formaction="@Url.Action("Delete", "HealthRecord")"
                    formmethod="post" formnovalidate class="btn btn-outline-danger ms-auto cancel"
                    onclick="return confirm('この体調記録を削除します。よろしいですか？');">削除</button>
        }
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const dateInput = document.getElementById('RecordDate');
        const timingSelect = document.querySelector('[data-health-record-timing-select]');
        const customTimeWrap = document.querySelector('[data-health-record-custom-time-wrap]');
        const customTimeInput = document.querySelector('[data-health-record-custom-time]');
        const idInput = document.getElementById('Id');
        if (!dateInput || !timingSelect) return;

        const customTimingValue = '@((int)RecordTiming.Custom)';

        if (window.PhycockTimeInput) {
            window.PhycockTimeInput.init(document);
        }

        updateCustomTimeVisibility();

        dateInput.addEventListener('change', function () {
            refreshDisabledTimings();
        });
        timingSelect.addEventListener('change', function () {
            updateCustomTimeVisibility();
        });

        function updateCustomTimeVisibility() {
            const isCustom = timingSelect.value === customTimingValue;
            if (customTimeWrap) {
                customTimeWrap.classList.toggle('d-none', !isCustom);
            }
            if (customTimeInput) {
                customTimeInput.disabled = !isCustom;
                if (isCustom && !customTimeInput.value) {
                    customTimeInput.value = currentTimeValue();
                }
            }
        }

        function currentTimeValue() {
            const now = new Date();
            const hh = String(now.getHours()).padStart(2, '0');
            const mm = String(now.getMinutes()).padStart(2, '0');
            return hh + ':' + mm;
        }

        function refreshDisabledTimings() {
            const params = new URLSearchParams({ recordDate: dateInput.value });
            if (idInput && idInput.value && idInput.value !== '0') {
                params.append('id', idInput.value);
            }

            fetch('@Url.Action("GetDisabledTimings", "HealthRecord")?' + params.toString(), {
                headers: { 'Accept': 'application/json' }
            })
                .then(function (response) {
                    if (!response.ok) return [];
                    return response.json();
                })
                .then(function (disabledValues) {
                    applyDisabledTimings(disabledValues.map(String));
                });
        }

        function applyDisabledTimings(disabledValues) {
            Array.from(timingSelect.options).forEach(function (option) {
                option.disabled = disabledValues.includes(option.value);
            });
            const customOption = Array.from(timingSelect.options).find(function (option) {
                return option.value === customTimingValue;
            });
            if (customOption) customOption.disabled = false;

            if (timingSelect.selectedOptions.length > 0 && timingSelect.selectedOptions[0].disabled) {
                const firstEnabled = Array.from(timingSelect.options).find(function (option) {
                    return !option.disabled;
                });
                if (firstEnabled) timingSelect.value = firstEnabled.value;
            }
            updateCustomTimeVisibility();
        }
    });
</script>
