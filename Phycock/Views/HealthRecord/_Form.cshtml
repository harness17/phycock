@model Phycock.Models.HealthRecordFormViewModel

<form method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="UserId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="RecordDate" class="form-label"></label>
            <input asp-for="RecordDate" type="date" class="form-control" />
            <span asp-validation-for="RecordDate" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="RecordTiming" class="form-label"></label>
            <select asp-for="RecordTiming" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.RecordTiming>()" class="form-select"></select>
        </div>
        <div class="col-md-2">
            <label asp-for="Condition" class="form-label"></label>
            <select asp-for="Condition" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.ConditionLevel>()" class="form-select"></select>
            <span asp-validation-for="Condition" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="Feeling" class="form-label"></label>
            <select asp-for="Feeling" asp-items="Html.GetEnumSelectList<Phycock.Entity.Enums.FeelingLevel>()" class="form-select"></select>
            <span asp-validation-for="Feeling" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-label">症状</label>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var symptom in Enum.GetValues<SymptomType>().Where(x => x != SymptomType.None))
                {
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedSymptoms" value="@symptom" checked="@Model.SelectedSymptoms.Contains(symptom)" />
                        <span class="form-check-label">@symptom.GetDisplayName()</span>
                    </label>
                }
            </div>
        </div>
        <div class="col-12">
            <label asp-for="Memo" class="form-label"></label>
            <textarea asp-for="Memo" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Memo" class="text-danger"></span>
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">保存</button>
        <a asp-action="Index" class="btn btn-outline-secondary">戻る</a>
    </div>
</form>
