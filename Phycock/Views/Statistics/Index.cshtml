@model Phycock.Models.StatisticsViewModel
@{
    ViewData["Title"] = "統計";
    var isPrint = Context.Request.Query["print"] == "1";
    if (isPrint)
    {
        ViewData["Print"] = true;
    }
    var weekStart = Model.WeeklyReport.WeekStart;
    var weekStartIso = weekStart.ToString("yyyy-MM-dd");
    var report = Model.WeeklyReport;
    var monthlyCalendar = Model.MonthlyCalendar;
    // PDF出力時の対象セクション（print=1 のときのみ有効）。monthly 以外は weekly 扱い。
    var printSection = Context.Request.Query["section"] == "monthly" ? "monthly" : "weekly";
    var printWeekly = !isPrint || printSection == "weekly";
    var printMonthly = !isPrint || printSection == "monthly";

    string ScoreClass(double? value)
    {
        if (value is not double v) return "score-none";
        if (v < 1.5) return "score-1";
        if (v < 2.5) return "score-2";
        if (v < 3.5) return "score-3";
        if (v < 4.5) return "score-4";
        return "score-5";
    }
}

@if (!isPrint)
{
<div class="statistics-toolbar d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">統計</h1>
    <div class="d-flex gap-2 align-items-center">
        <input id="weekStart" type="date" class="form-control" />
        <button id="reloadStats" type="button" class="btn btn-outline-primary text-nowrap">更新</button>
        <button id="exportPdf" type="button" class="btn btn-outline-secondary text-nowrap">
            <i class="fa-regular fa-file-pdf"></i> PDF出力
        </button>
    </div>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#weekly" type="button" role="tab">週次</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">月次</button>
    </li>
</ul>
}

<div class="tab-content">
    @if (printWeekly)
    {
    <div class="@(isPrint ? "" : "tab-pane fade show active")" id="weekly" role="tabpanel">
        <section class="weekly-report-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">週次レポート</h2>
                    <p class="text-muted small mb-0">体調、睡眠内訳、通所予定、メモを一週間で確認します。</p>
                </div>
                <span class="text-muted small">@weekStart.ToString("yyyy/MM/dd") 〜 @weekStart.AddDays(6).ToString("yyyy/MM/dd")</span>
            </div>

            <div class="weekly-report-chart">
                <canvas id="weeklyReportSampleChart"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（7-9時間）</span>
            </div>

            <div class="weekly-schedule-strip mt-3" aria-label="通所スケジュール">
                @foreach (var day in report.Days)
                {
                    <div class="schedule-day @day.ScheduleDayClass">
                        <span class="schedule-date">@day.Date.Month/@day.Date.Day</span>
                        @foreach (var s in day.ScheduleStrip)
                        {
                            <div class="schedule-entry @s.StatusClass">
                                <strong>@s.SessionLabel</strong>
                                @if (!string.IsNullOrEmpty(s.DetailLabel))
                                {
                                    <small>@s.DetailLabel</small>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="table-responsive mt-3 weekly-report-table-wrap">
                <table class="table table-sm align-middle weekly-report-table">
                    <thead>
                        <tr>
                            <th scope="col">日付</th>
                            <th scope="col">体調平均</th>
                            <th scope="col">気分平均</th>
                            <th scope="col">本睡眠</th>
                            <th scope="col">他睡眠</th>
                            <th scope="col">通所</th>
                            <th scope="col">体調記録の内訳（記録タイミング別）</th>
                            <th scope="col">睡眠記録メモ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in report.Days)
                        {
                            <tr>
                                <th scope="row">@d.DayLabel</th>
                                <td>@(d.ConditionAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.FeelingAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.NightSleepHours > 0 ? $"{d.NightSleepHours:0.0}h" : "-")</td>
                                <td>@(d.OtherSleepHours > 0 ? $"{d.OtherSleepHours:0.0}h" : "-")</td>
                                <td>
                                    @foreach (var line in d.ScheduleSummaryLines)
                                    {
                                        <div>@line</div>
                                    }
                                </td>
                                <td>
                                    @if (d.HealthRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var h in d.HealthRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@h.TimingLabel</strong>
                                            <span>
                                                体調 @h.ConditionLabel / 気分 @h.FeelingLabel / 症状: @h.SymptomsLabel
                                                @if (!string.IsNullOrEmpty(h.Memo))
                                                {
                                                    <span class="record-memo">メモ: @h.Memo</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (d.SleepRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var s in d.SleepRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@s.TypeLabel</strong>
                                            <span>
                                                @($"{s.Hours:0.0}h")@(string.IsNullOrEmpty(s.Memo) ? "" : $" / {s.Memo}")
                                            </span>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="weekly-timeline-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">睡眠時間帯 週次タイムライン</h2>
                    <p class="text-muted small mb-0">1日24時間軸で睡眠と通所予定の時間帯を一週間まとめて確認します。日跨ぎ睡眠は前後の日に分割表示。</p>
                </div>
            </div>

            <div class="weekly-timeline-chart">
                <canvas id="weeklyTimelineSampleChart"></canvas>
            </div>
            <div class="timeline-legend mt-2">
                <span class="legend-item"><span class="legend-swatch" style="background:#5B7CFA;"></span>本睡眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#8DD7BF;"></span>他睡眠 / 仮眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#F59F00;"></span>通所予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch legend-swatch-dashed"></span>通所予定 欠席（破線）</span>
                <span class="legend-item text-muted">※ 早退時は予定時間を短縮表示</span>
            </div>
        </section>
    </div>
    }
    @if (printMonthly)
    {
    <div class="@(isPrint ? "" : "tab-pane fade")" id="monthly" role="tabpanel">
        <section class="monthly-calendar mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">月次カレンダー</h2>
                    <p class="text-muted small mb-0">体調、気分、睡眠合計、通所予定を日別に確認します。</p>
                </div>
                <span class="text-muted small">@monthlyCalendar.Year/@monthlyCalendar.Month.ToString("00")</span>
            </div>

            <div class="monthly-calendar-grid" role="table" aria-label="月次統計カレンダー">
                <div class="monthly-weekdays" role="row">
                    <div role="columnheader">日</div>
                    <div role="columnheader">月</div>
                    <div role="columnheader">火</div>
                    <div role="columnheader">水</div>
                    <div role="columnheader">木</div>
                    <div role="columnheader">金</div>
                    <div role="columnheader">土</div>
                </div>
                <div class="monthly-days" role="rowgroup">
                    @{ var weekIndex = 0; }
                    @foreach (var week in monthlyCalendar.Cells.Chunk(7))
                    {
                        // 3週ごとに改ページ（PDF出力時に週行が途中で切れないようにする）
                        var weekBreak = weekIndex > 0 && weekIndex % 3 == 0 ? " monthly-week-break" : "";
                        <div class="monthly-week@(weekBreak)" role="row">
                            @foreach (var cell in week)
                            {
                                var sleepClass = $"sleep-{cell.SleepLevel.ToString().ToLowerInvariant()}";
                                var scheduleClass = $"schedule-{cell.ScheduleDayClass}";
                                <div class="monthly-day @(cell.InMonth ? "" : "outside-month")" role="cell">
                                    <div class="monthly-day-number">@cell.Date.Day</div>
                                    @if (cell.InMonth)
                                    {
                                        <div class="monthly-metrics">
                                            <span class="monthly-metric @ScoreClass(cell.ConditionAvg)">
                                                <span>体調</span>
                                                <strong>@(cell.ConditionAvg?.ToString("0.0") ?? "-")</strong>
                                            </span>
                                            <span class="monthly-metric @ScoreClass(cell.FeelingAvg)">
                                                <span>気分</span>
                                                <strong>@(cell.FeelingAvg?.ToString("0.0") ?? "-")</strong>
                                            </span>
                                            <span class="monthly-metric @sleepClass">
                                                <span>睡眠</span>
                                                <strong>@($"{cell.SleepTotalHours:0.0}h")</strong>
                                            </span>
                                            <span class="monthly-schedule-chip @scheduleClass">@cell.ScheduleSummary</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        weekIndex++;
                    }
                </div>
            </div>

            <div class="monthly-legend mt-3" aria-label="凡例">
                <span class="legend-item"><span class="legend-swatch score-1"></span>体調・気分 1</span>
                <span class="legend-item"><span class="legend-swatch score-3"></span>体調・気分 3</span>
                <span class="legend-item"><span class="legend-swatch score-5"></span>体調・気分 5</span>
                <span class="legend-item"><span class="legend-swatch sleep-insufficient"></span>睡眠 &lt;6h</span>
                <span class="legend-item"><span class="legend-swatch sleep-slightlyshort"></span>睡眠 6-7h</span>
                <span class="legend-item"><span class="legend-swatch sleep-adequate"></span>睡眠 7-9h</span>
                <span class="legend-item"><span class="legend-swatch sleep-excessive"></span>睡眠 &gt;9h</span>
                <span class="legend-item"><span class="legend-swatch schedule-planned"></span>通所</span>
                <span class="legend-item"><span class="legend-swatch schedule-remote"></span>在宅</span>
                <span class="legend-item"><span class="legend-swatch schedule-rest"></span>予定なし</span>
            </div>
        </section>

        <section class="monthly-chart">
            <h2 class="h5 mb-1">月次 体調・気分・睡眠</h2>
            <p class="text-muted small mb-3">体調・気分の推移と睡眠内訳を月単位で確認します。</p>
            <div class="monthly-report-chart">
                <canvas id="monthlyReportChart"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（7-9時間）</span>
            </div>
        </section>
    </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        const isPrintMode = @(isPrint ? "true" : "false");
        const printSection = '@printSection';
        const currentWeekStart = '@weekStartIso';
        // サーバー側（DBデータ）から注入するチャート用データ
        const reportChartData = @Html.Raw(Json.Serialize(report.ReportChart));
        const timelineChartData = @Html.Raw(Json.Serialize(report.TimelineChart));
        const monthlyReportChartData = @Html.Raw(Json.Serialize(Model.MonthlyCalendar.ReportChart));
        let weeklyReportSampleChart;
        let monthlyReportChart;

        const sleepTargetBandPlugin = {
            id: 'sleepTargetBand',
            beforeDatasetsDraw(chart, args, pluginOptions) {
                const yScale = chart.scales.sleepHours;
                const { chartArea, ctx } = chart;
                if (!yScale || !chartArea || pluginOptions?.enabled === false) return;

                const from = pluginOptions?.from ?? 7;
                const to = pluginOptions?.to ?? 9;
                const yTop = yScale.getPixelForValue(to);
                const yBottom = yScale.getPixelForValue(from);

                ctx.save();
                ctx.fillStyle = pluginOptions?.color ?? 'rgba(255, 193, 7, 0.16)';
                ctx.fillRect(chartArea.left, yTop, chartArea.right - chartArea.left, yBottom - yTop);
                ctx.strokeStyle = pluginOptions?.borderColor ?? 'rgba(245, 159, 0, 0.45)';
                ctx.setLineDash([4, 4]);
                ctx.beginPath();
                ctx.moveTo(chartArea.left, yTop);
                ctx.lineTo(chartArea.right, yTop);
                ctx.moveTo(chartArea.left, yBottom);
                ctx.lineTo(chartArea.right, yBottom);
                ctx.stroke();
                ctx.restore();
            }
        };

        // 週次・月次共用の複合チャート設定（棒=睡眠内訳 / 折れ線=体調・気分）
        function reportChartConfig(chartData) {
            const data = {
                labels: chartData.labels,
                datasets: [
                    {
                        type: 'bar',
                        label: '本睡眠',
                        data: chartData.nightSleep,
                        backgroundColor: '#5B7CFA',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'bar',
                        label: '他睡眠',
                        data: chartData.otherSleep,
                        backgroundColor: '#8DD7BF',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'line',
                        label: '体調',
                        data: chartData.condition,
                        borderColor: '#E05D44',
                        backgroundColor: '#E05D44',
                        borderWidth: 3,
                        order: 1,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    },
                    {
                        type: 'line',
                        label: '気分',
                        data: chartData.feeling,
                        borderColor: '#F59F00',
                        backgroundColor: '#F59F00',
                        borderDash: [6, 3],
                        borderWidth: 3,
                        order: 0,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    }
                ]
            };
            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'bottom' },
                    sleepTargetBand: {
                        from: 7,
                        to: 9,
                        color: 'rgba(255, 193, 7, 0.16)',
                        borderColor: 'rgba(245, 159, 0, 0.45)'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const suffix = context.dataset.yAxisID === 'sleepHours' ? 'h' : '';
                                return `${context.dataset.label}: ${context.parsed.y}${suffix}`;
                            }
                        }
                    }
                },
                scales: {
                    x: { stacked: true },
                    sleepHours: {
                        type: 'linear',
                        position: 'left',
                        stacked: true,
                        min: 0,
                        max: 10,
                        title: { display: true, text: '睡眠時間' }
                    },
                    conditionScore: {
                        type: 'linear',
                        position: 'right',
                        min: 1,
                        max: 5,
                        grid: { drawOnChartArea: false },
                        title: { display: true, text: '体調・気分' }
                    }
                }
            };

            return { data, options };
        }

        function createWeeklyReportSampleChart() {
            const { data, options } = reportChartConfig(reportChartData);
            if (weeklyReportSampleChart) {
                weeklyReportSampleChart.data = data;
                weeklyReportSampleChart.options = options;
                weeklyReportSampleChart.update();
                return;
            }

            weeklyReportSampleChart = new Chart(document.getElementById('weeklyReportSampleChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        function createMonthlyReportChart() {
            const { data, options } = reportChartConfig(monthlyReportChartData);
            monthlyReportChart = new Chart(document.getElementById('monthlyReportChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        let weeklyTimelineSampleChart;

        function createWeeklyTimelineSampleChart() {
            // 縦軸: 7日。横軸: 0-24h。データは [開始時刻, 終了時刻] の浮動バー。
            // null は当該日に該当無し。日跨ぎ睡眠は前後の日に分割済み（サーバー側で計算）。
            const labels = timelineChartData.labels;
            const nightSleepEarly = timelineChartData.nightSleepEarly;
            const nightSleepLate = timelineChartData.nightSleepLate;
            const otherSleep = timelineChartData.otherSleep;
            const scheduleAm = timelineChartData.scheduleAm;
            const scheduleAbsent = timelineChartData.scheduleAbsent;
            const schedulePm = timelineChartData.schedulePm;

            const data = {
                labels: labels,
                datasets: [
                    {
                        label: '本睡眠',
                        data: nightSleepEarly,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '本睡眠（夜）',
                        data: nightSleepLate,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '他睡眠 / 仮眠',
                        data: otherSleep,
                        backgroundColor: '#8DD7BF',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 AM',
                        data: scheduleAm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 PM',
                        data: schedulePm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 欠席',
                        data: scheduleAbsent,
                        backgroundColor: 'rgba(245, 159, 0, 0.10)',
                        borderColor: '#F59F00',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    }
                ]
            };

            const formatHour = (v) => {
                const h = Math.floor(v);
                const m = Math.round((v - h) * 60);
                return m === 0 ? `${h}:00` : `${h}:${String(m).padStart(2, '0')}`;
            };

            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                indexAxis: 'y',
                interaction: { mode: 'nearest', intersect: true },
                plugins: {
                    legend: {
                        display: false  // 凡例は HTML 側で表示（本睡眠2バーの重複を避ける）
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const v = context.raw;
                                if (!v) return '';
                                return `${context.dataset.label}: ${formatHour(v[0])} - ${formatHour(v[1])}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        position: 'bottom',
                        min: 0,
                        max: 24,
                        title: { display: true, text: '時刻 (0:00 - 24:00)' },
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: {
                            color: (ctx) => ctx.tick && ctx.tick.value % 3 === 0
                                ? 'rgba(0,0,0,0.18)'
                                : 'rgba(0,0,0,0.07)',
                            lineWidth: 1
                        }
                    },
                    xTop: {
                        type: 'linear',
                        position: 'top',
                        min: 0,
                        max: 24,
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: { display: false }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 13 } }
                    }
                }
            };

            if (weeklyTimelineSampleChart) {
                weeklyTimelineSampleChart.data = data;
                weeklyTimelineSampleChart.options = options;
                weeklyTimelineSampleChart.update();
                return;
            }

            weeklyTimelineSampleChart = new Chart(
                document.getElementById('weeklyTimelineSampleChart'),
                { type: 'bar', data: data, options: options }
            );
        }

        if (isPrintMode) {
            // ポイント: print=1 のときはサーバー側 Playwright が描画完了を window.chartsReady で検知する
            // section に応じて描画するチャートを切り替える（不在の canvas を触らない）
            if (printSection === 'monthly') {
                createMonthlyReportChart();
            } else {
                createWeeklyReportSampleChart();
                createWeeklyTimelineSampleChart();
            }
            // requestAnimationFrame 2回でレイアウト確定 → chartsReady を立てる
            requestAnimationFrame(() => requestAnimationFrame(() => {
                window.chartsReady = true;
            }));
        } else {
            $('#weekStart').val(currentWeekStart);
            // 「更新」: 週次レポートはサーバー再取得が必要なのでページ遷移する
            $('#reloadStats').on('click', function () {
                const ws = $('#weekStart').val();
                window.location.href = '@Url.Action("Index", "Statistics")' + '?weekStart=' + encodeURIComponent(ws);
            });
            // PDF出力: アクティブなタブ（週次/月次）に応じて出力対象を切り替える
            $('#exportPdf').on('click', function () {
                const ws = $('#weekStart').val();
                const activeTab = document.querySelector('.nav-tabs .nav-link.active');
                const section = activeTab?.dataset.bsTarget === '#monthly' ? 'monthly' : 'weekly';
                window.location.href = '@Url.Action("ExportPdf", "Statistics")'
                    + '?weekStart=' + encodeURIComponent(ws) + '&section=' + section;
            });
            createWeeklyReportSampleChart();
            createWeeklyTimelineSampleChart();
            createMonthlyReportChart();
        }
    </script>
}

<style>
    .weekly-report-sample {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

