@model Phycock.Models.StatisticsViewModel
@{
    ViewData["Title"] = "統計";
    var isPrint = Context.Request.Query["print"] == "1";
    if (isPrint)
    {
        ViewData["Print"] = true;
    }
    var weekStart = Model.WeeklyReport.WeekStart;
    var weekStartIso = weekStart.ToString("yyyy-MM-dd");
    var report = Model.WeeklyReport;
}

@if (!isPrint)
{
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">統計</h1>
    <div class="d-flex gap-2">
        <input id="weekStart" type="date" class="form-control" />
        <button id="reloadStats" type="button" class="btn btn-outline-primary">更新</button>
        <button id="exportPdf" type="button" class="btn btn-outline-secondary">
            <i class="fa-regular fa-file-pdf"></i> PDF出力
        </button>
    </div>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#weekly" type="button" role="tab">週次</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">月次</button>
    </li>
</ul>
}

<div class="tab-content">
    <div class="@(isPrint ? "" : "tab-pane fade show active")" id="weekly" role="tabpanel">
        <section class="weekly-report-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">週次レポート</h2>
                    <p class="text-muted small mb-0">体調、睡眠内訳、通所予定、メモを一週間で確認します。</p>
                </div>
                <span class="text-muted small">@weekStart.ToString("yyyy/MM/dd") 〜 @weekStart.AddDays(6).ToString("yyyy/MM/dd")</span>
            </div>

            <div class="weekly-report-chart">
                <canvas id="weeklyReportSampleChart"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（6-8時間）</span>
            </div>

            <div class="weekly-schedule-strip mt-3" aria-label="通所スケジュール">
                @foreach (var day in report.Days)
                {
                    <div class="schedule-day @day.ScheduleDayClass">
                        <span class="schedule-date">@day.Date.Month/@day.Date.Day</span>
                        @foreach (var s in day.ScheduleStrip)
                        {
                            <div class="schedule-entry @s.StatusClass">
                                <strong>@s.SessionLabel</strong>
                                @if (!string.IsNullOrEmpty(s.DetailLabel))
                                {
                                    <small>@s.DetailLabel</small>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="table-responsive mt-3">
                <table class="table table-sm align-middle weekly-report-table">
                    <thead>
                        <tr>
                            <th scope="col">日付</th>
                            <th scope="col">体調平均</th>
                            <th scope="col">気分平均</th>
                            <th scope="col">本睡眠</th>
                            <th scope="col">他睡眠</th>
                            <th scope="col">通所</th>
                            <th scope="col">体調記録の内訳（記録タイミング別）</th>
                            <th scope="col">睡眠記録メモ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in report.Days)
                        {
                            <tr>
                                <th scope="row">@d.DayLabel</th>
                                <td>@(d.ConditionAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.FeelingAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.NightSleepHours > 0 ? $"{d.NightSleepHours:0.0}h" : "-")</td>
                                <td>@(d.OtherSleepHours > 0 ? $"{d.OtherSleepHours:0.0}h" : "-")</td>
                                <td>@d.ScheduleSummary</td>
                                <td>
                                    @if (d.HealthRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var h in d.HealthRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@h.TimingLabel</strong>
                                            <span>
                                                体調 @h.ConditionLabel / 気分 @h.FeelingLabel / 症状: @h.SymptomsLabel
                                                @if (!string.IsNullOrEmpty(h.Memo))
                                                {
                                                    <span class="record-memo">メモ: @h.Memo</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (d.SleepRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var s in d.SleepRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@s.TypeLabel</strong>
                                            <span>
                                                @($"{s.Hours:0.0}h")@(string.IsNullOrEmpty(s.Memo) ? "" : $" / {s.Memo}")
                                            </span>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="weekly-timeline-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">睡眠時間帯 週次タイムライン</h2>
                    <p class="text-muted small mb-0">1日24時間軸で睡眠と通所予定の時間帯を一週間まとめて確認します。日跨ぎ睡眠は前後の日に分割表示。</p>
                </div>
            </div>

            <div class="weekly-timeline-chart">
                <canvas id="weeklyTimelineSampleChart"></canvas>
            </div>
            <div class="timeline-legend mt-2">
                <span class="legend-item"><span class="legend-swatch" style="background:#5B7CFA;"></span>本睡眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#8DD7BF;"></span>他睡眠 / 仮眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#F59F00;"></span>通所予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch legend-swatch-dashed"></span>通所予定 欠席（破線）</span>
                <span class="legend-item text-muted">※ 早退時は予定時間を短縮表示</span>
            </div>
        </section>

        @if (!isPrint)
        {
        <div class="row">
            <div class="col-lg-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">体調・気分</h5>
                        <canvas id="weeklyHealthChart" height="160"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">睡眠時間</h5>
                        <canvas id="weeklySleepChart" height="160"></canvas>
                    </div>
                </div>
            </div>
        </div>
        }
    </div>
    @if (!isPrint)
    {
    <div class="tab-pane fade" id="monthly" role="tabpanel">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">月次 体調・気分</h5>
                <canvas id="monthlyHealthChart" height="120"></canvas>
            </div>
        </div>
    </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        const isPrintMode = @(isPrint ? "true" : "false");
        const currentWeekStart = '@weekStartIso';
        // サーバー側（DBデータ）から注入するチャート用データ
        const reportChartData = @Html.Raw(Json.Serialize(report.ReportChart));
        const timelineChartData = @Html.Raw(Json.Serialize(report.TimelineChart));
        let weeklyHealthChart;
        let weeklySleepChart;
        let monthlyHealthChart;
        let weeklyReportSampleChart;
        const statisticsUrls = {
            healthWeekly: '@Url.Action("GetHealthWeekly", "Statistics")',
            sleepWeekly: '@Url.Action("GetSleepWeekly", "Statistics")',
            healthMonthly: '@Url.Action("GetHealthMonthly", "Statistics")'
        };

        function createOrUpdateLineChart(chart, canvasId, labels, conditionData, feelingData) {
            const data = {
                labels: labels,
                datasets: [
                    { label: '体調', data: conditionData, borderColor: '#0d6efd', backgroundColor: '#0d6efd', tension: 0.25 },
                    { label: '気分', data: feelingData, borderColor: '#F59F00', backgroundColor: '#F59F00', tension: 0.25 }
                ]
            };
            if (chart) {
                chart.data = data;
                chart.update();
                return chart;
            }
            return new Chart(document.getElementById(canvasId), { type: 'line', data: data });
        }

        function createOrUpdateBarChart(chart, canvasId, labels, sleepHoursData) {
            const data = {
                labels: labels,
                datasets: [{ label: '睡眠時間', data: sleepHoursData, backgroundColor: '#6f42c1' }]
            };
            if (chart) {
                chart.data = data;
                chart.update();
                return chart;
            }
            return new Chart(document.getElementById(canvasId), { type: 'bar', data: data });
        }

        const sleepTargetBandPlugin = {
            id: 'sleepTargetBand',
            beforeDatasetsDraw(chart, args, pluginOptions) {
                const yScale = chart.scales.sleepHours;
                const { chartArea, ctx } = chart;
                if (!yScale || !chartArea || pluginOptions?.enabled === false) return;

                const from = pluginOptions?.from ?? 6;
                const to = pluginOptions?.to ?? 8;
                const yTop = yScale.getPixelForValue(to);
                const yBottom = yScale.getPixelForValue(from);

                ctx.save();
                ctx.fillStyle = pluginOptions?.color ?? 'rgba(255, 193, 7, 0.16)';
                ctx.fillRect(chartArea.left, yTop, chartArea.right - chartArea.left, yBottom - yTop);
                ctx.strokeStyle = pluginOptions?.borderColor ?? 'rgba(245, 159, 0, 0.45)';
                ctx.setLineDash([4, 4]);
                ctx.beginPath();
                ctx.moveTo(chartArea.left, yTop);
                ctx.lineTo(chartArea.right, yTop);
                ctx.moveTo(chartArea.left, yBottom);
                ctx.lineTo(chartArea.right, yBottom);
                ctx.stroke();
                ctx.restore();
            }
        };

        function createWeeklyReportSampleChart() {
            const data = {
                labels: reportChartData.labels,
                datasets: [
                    {
                        type: 'bar',
                        label: '本睡眠',
                        data: reportChartData.nightSleep,
                        backgroundColor: '#5B7CFA',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'bar',
                        label: '他睡眠',
                        data: reportChartData.otherSleep,
                        backgroundColor: '#8DD7BF',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'line',
                        label: '体調',
                        data: reportChartData.condition,
                        borderColor: '#E05D44',
                        backgroundColor: '#E05D44',
                        borderWidth: 3,
                        order: 1,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    },
                    {
                        type: 'line',
                        label: '気分',
                        data: reportChartData.feeling,
                        borderColor: '#F59F00',
                        backgroundColor: '#F59F00',
                        borderDash: [6, 3],
                        borderWidth: 3,
                        order: 0,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    }
                ]
            };
            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'bottom' },
                    sleepTargetBand: {
                        from: 6,
                        to: 8,
                        color: 'rgba(255, 193, 7, 0.16)',
                        borderColor: 'rgba(245, 159, 0, 0.45)'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const suffix = context.dataset.yAxisID === 'sleepHours' ? 'h' : '';
                                return `${context.dataset.label}: ${context.parsed.y}${suffix}`;
                            }
                        }
                    }
                },
                scales: {
                    x: { stacked: true },
                    sleepHours: {
                        type: 'linear',
                        position: 'left',
                        stacked: true,
                        min: 0,
                        max: 10,
                        title: { display: true, text: '睡眠時間' }
                    },
                    conditionScore: {
                        type: 'linear',
                        position: 'right',
                        min: 1,
                        max: 5,
                        grid: { drawOnChartArea: false },
                        title: { display: true, text: '体調・気分' }
                    }
                }
            };

            if (weeklyReportSampleChart) {
                weeklyReportSampleChart.data = data;
                weeklyReportSampleChart.options = options;
                weeklyReportSampleChart.update();
                return;
            }

            weeklyReportSampleChart = new Chart(document.getElementById('weeklyReportSampleChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        function loadStats() {
            const weekStart = $('#weekStart').val();
            const date = new Date(weekStart + 'T00:00:00');
            $.get(statisticsUrls.healthWeekly, { weekStart: weekStart }, function (data) {
                weeklyHealthChart = createOrUpdateLineChart(
                    weeklyHealthChart,
                    'weeklyHealthChart',
                    data.labels,
                    data.conditionData,
                    data.feelingData);
            });
            $.get(statisticsUrls.sleepWeekly, { weekStart: weekStart }, function (data) {
                weeklySleepChart = createOrUpdateBarChart(
                    weeklySleepChart,
                    'weeklySleepChart',
                    data.labels,
                    data.sleepHoursData);
            });
            $.get(statisticsUrls.healthMonthly, { year: date.getFullYear(), month: date.getMonth() + 1 }, function (data) {
                monthlyHealthChart = createOrUpdateLineChart(
                    monthlyHealthChart,
                    'monthlyHealthChart',
                    data.labels,
                    data.conditionData,
                    data.feelingData);
            });
        }

        let weeklyTimelineSampleChart;

        function createWeeklyTimelineSampleChart() {
            // 縦軸: 7日。横軸: 0-24h。データは [開始時刻, 終了時刻] の浮動バー。
            // null は当該日に該当無し。日跨ぎ睡眠は前後の日に分割済み（サーバー側で計算）。
            const labels = timelineChartData.labels;
            const nightSleepEarly = timelineChartData.nightSleepEarly;
            const nightSleepLate = timelineChartData.nightSleepLate;
            const otherSleep = timelineChartData.otherSleep;
            const scheduleAm = timelineChartData.scheduleAm;
            const scheduleAbsent = timelineChartData.scheduleAbsent;
            const schedulePm = timelineChartData.schedulePm;

            const data = {
                labels: labels,
                datasets: [
                    {
                        label: '本睡眠',
                        data: nightSleepEarly,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '本睡眠（夜）',
                        data: nightSleepLate,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '他睡眠 / 仮眠',
                        data: otherSleep,
                        backgroundColor: '#8DD7BF',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 AM',
                        data: scheduleAm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 PM',
                        data: schedulePm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 欠席',
                        data: scheduleAbsent,
                        backgroundColor: 'rgba(245, 159, 0, 0.10)',
                        borderColor: '#F59F00',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    }
                ]
            };

            const formatHour = (v) => {
                const h = Math.floor(v);
                const m = Math.round((v - h) * 60);
                return m === 0 ? `${h}:00` : `${h}:${String(m).padStart(2, '0')}`;
            };

            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                indexAxis: 'y',
                interaction: { mode: 'nearest', intersect: true },
                plugins: {
                    legend: {
                        display: false  // 凡例は HTML 側で表示（本睡眠2バーの重複を避ける）
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const v = context.raw;
                                if (!v) return '';
                                return `${context.dataset.label}: ${formatHour(v[0])} - ${formatHour(v[1])}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        position: 'bottom',
                        min: 0,
                        max: 24,
                        title: { display: true, text: '時刻 (0:00 - 24:00)' },
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: {
                            color: (ctx) => ctx.tick && ctx.tick.value % 3 === 0
                                ? 'rgba(0,0,0,0.18)'
                                : 'rgba(0,0,0,0.07)',
                            lineWidth: 1
                        }
                    },
                    xTop: {
                        type: 'linear',
                        position: 'top',
                        min: 0,
                        max: 24,
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: { display: false }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 13 } }
                    }
                }
            };

            if (weeklyTimelineSampleChart) {
                weeklyTimelineSampleChart.data = data;
                weeklyTimelineSampleChart.options = options;
                weeklyTimelineSampleChart.update();
                return;
            }

            weeklyTimelineSampleChart = new Chart(
                document.getElementById('weeklyTimelineSampleChart'),
                { type: 'bar', data: data, options: options }
            );
        }

        if (isPrintMode) {
            // ポイント: print=1 のときはサーバー側 Playwright が描画完了を window.chartsReady で検知する
            createWeeklyReportSampleChart();
            createWeeklyTimelineSampleChart();
            // requestAnimationFrame 2回でレイアウト確定 → chartsReady を立てる
            requestAnimationFrame(() => requestAnimationFrame(() => {
                window.chartsReady = true;
            }));
        } else {
            $('#weekStart').val(currentWeekStart);
            // 「更新」: 週次レポートはサーバー再取得が必要なのでページ遷移する
            $('#reloadStats').on('click', function () {
                const ws = $('#weekStart').val();
                window.location.href = '@Url.Action("Index", "Statistics")' + '?weekStart=' + encodeURIComponent(ws);
            });
            $('#exportPdf').on('click', function () {
                const ws = $('#weekStart').val();
                window.location.href = '@Url.Action("ExportPdf", "Statistics")' + '?weekStart=' + encodeURIComponent(ws);
            });
            createWeeklyReportSampleChart();
            createWeeklyTimelineSampleChart();
            loadStats();
        }
    </script>
}

<style>
    .weekly-report-sample {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    /* チャート枠：明示的な高さで maintainAspectRatio:false と組み合わせる */
    .weekly-report-chart {
        position: relative;
        height: 320px;
    }

    .weekly-report-chart canvas,
    .weekly-timeline-chart canvas {
        max-width: 100% !important;
    }

    .chart-guide {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #6c757d;
        font-size: 0.85rem;
    }

    .sleep-target-swatch {
        width: 1.6rem;
        height: 0.7rem;
        border: 1px dashed rgba(245, 159, 0, 0.6);
        background: rgba(255, 193, 7, 0.18);
        border-radius: 3px;
        flex: 0 0 auto;
    }

    .weekly-schedule-strip {
        display: grid;
        grid-template-columns: repeat(7, minmax(96px, 1fr));
        gap: 0.5rem;
        overflow-x: auto;
        padding-bottom: 0.25rem;
    }

    .schedule-day {
        min-height: 96px;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        white-space: nowrap;
    }

    .schedule-date {
        font-size: 0.78rem;
        color: #6c757d;
    }

    .schedule-entry {
        border-radius: 5px;
        padding: 0.35rem 0.45rem;
        display: flex;
        flex-direction: column;
        gap: 0.05rem;
        background: rgba(255, 255, 255, 0.75);
        border-left: 4px solid #adb5bd;
    }

    .schedule-entry strong {
        font-size: 0.86rem;
        line-height: 1.2;
    }

    .schedule-entry small {
        color: #495057;
        font-size: 0.74rem;
    }

    .schedule-entry.status-attended {
        border-left-color: #198754;
    }

    .schedule-entry.status-planned {
        border-left-color: #0d6efd;
    }

    .schedule-entry.status-late {
        border-left-color: #fd7e14;
    }

    .schedule-entry.status-early-leave {
        border-left-color: #6f42c1;
    }

    .schedule-entry.status-absent {
        border-left-color: #dc3545;
    }

    .schedule-entry.status-none {
        border-left-color: #adb5bd;
    }

    .schedule-day.planned {
        background: #E7F1FF;
        border-color: #9EC5FE;
    }

    .schedule-day.remote {
        background: #E8F6EF;
        border-color: #A3CFBB;
    }

    .schedule-day.rest {
        background: #F8F9FA;
        border-color: #CED4DA;
    }

    .weekly-report-table th,
    .weekly-report-table td {
        min-width: 88px;
    }

    .weekly-report-table td:nth-last-child(-n+2) {
        min-width: 280px;
    }

    .record-note {
        display: grid;
        grid-template-columns: 5.5rem 1fr;
        gap: 0.4rem;
        padding: 0.25rem 0;
        border-bottom: 1px solid #edf0f2;
    }

    .record-note:last-child {
        border-bottom: 0;
    }

    .record-note strong {
        color: #495057;
    }

    .record-note span {
        min-width: 0;
    }

    .record-memo {
