@model Phycock.Models.StatisticsViewModel
@{
    ViewData["Title"] = "統計";
    var isPrint = Context.Request.Query["print"] == "1";
    if (isPrint)
    {
        ViewData["Print"] = true;
    }
    var weekStart = Model.WeeklyReport.WeekStart;
    var weekStartIso = weekStart.ToString("yyyy-MM-dd");
    var report = Model.WeeklyReport;
    var monthlyCalendar = Model.MonthlyCalendar;
    var weeklyReflection = Model.WeeklyReflection;
    var monthlyReflection = Model.MonthlyReflection;
    var monthStartIso = new DateTime(monthlyCalendar.Year, monthlyCalendar.Month, 1).ToString("yyyy-MM-dd");

    // 所感の各項目（ラベル + 値）を順序固定で列挙するためのヘルパー
    (string Label, string? Value)[] ReflectionRows(Phycock.Models.PeriodReflectionViewModel r) => new[]
    {
        ("自己評価", r.SelfEvaluation),
        ("負担", r.Burden),
        ("改善案", r.Improvement),
        ("食欲", r.Appetite),
        ("睡眠", r.Sleep)
    };
    // PDF出力時の対象セクション（print=1 のときのみ有効）。monthly 以外は weekly 扱い。
    var printSection = Context.Request.Query["section"] == "monthly" ? "monthly" : "weekly";
    var printWeekly = !isPrint || printSection == "weekly";
    var printMonthly = !isPrint || printSection == "monthly";
    // ?tab=monthly のときは月次タブを初期 active にする（更新ボタンからの遷移用）
    var initialTab = Context.Request.Query["tab"] == "monthly" ? "monthly" : "weekly";
    var weeklyActive = initialTab == "weekly";
    // 月次チャートで週区切りの縦線を引く位置（最初の日曜にあたるデータ点の index）
    var monthFirstDow = (int)new DateTime(monthlyCalendar.Year, monthlyCalendar.Month, 1).DayOfWeek;
    var monthlyWeekStartOffset = (7 - monthFirstDow) % 7;
    // プライベート色は ActivityType.Private の CalendarColor 属性を一元参照する
    var privateColor = ActivityType.Private.GetCalendarColor();

    string ScoreClass(double? value)
    {
        if (value is not double v) return "score-none";
        if (v < 1.5) return "score-1";
        if (v < 2.5) return "score-2";
        if (v < 3.5) return "score-3";
        if (v < 4.5) return "score-4";
        return "score-5";
    }
}

@if (!isPrint)
{
<div class="statistics-toolbar d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">統計</h1>
    <div class="d-flex gap-2 align-items-center">
        <button id="prevWeek" type="button" class="btn btn-outline-secondary text-nowrap" title="前週">
            <i class="fas fa-chevron-left"></i>
        </button>
        <input id="weekStart" type="date" class="form-control" />
        <button id="nextWeek" type="button" class="btn btn-outline-secondary text-nowrap" title="次週">
            <i class="fas fa-chevron-right"></i>
        </button>
        <button id="reloadStats" type="button" class="btn btn-outline-primary text-nowrap">更新</button>
        <button id="exportPdf" type="button" class="btn btn-outline-secondary text-nowrap">
            <span class="pdf-export-idle">
                <i class="fa-regular fa-file-pdf"></i> PDF出力
            </span>
            <span class="pdf-export-loading d-none">
                <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                作成中...
            </span>
        </button>
    </div>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(weeklyActive ? "active" : "")" data-bs-toggle="tab" data-bs-target="#weekly" type="button" role="tab">週次</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(weeklyActive ? "" : "active")" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">月次</button>
    </li>
</ul>
}

<div class="tab-content">
    @if (printWeekly)
    {
    <div class="@(isPrint ? "" : weeklyActive ? "tab-pane fade show active" : "tab-pane fade")" id="weekly" role="tabpanel">
        @{
            var weeklyRows = ReflectionRows(weeklyReflection);
            var weeklyHasInput = weeklyRows.Any(r => !string.IsNullOrWhiteSpace(r.Value));
        }
        @if (!isPrint)
        {
            <div class="d-flex justify-content-end mb-2">
                <button type="button" class="btn btn-outline-primary btn-sm"
                        data-bs-toggle="offcanvas" data-bs-target="#weeklyReflectionOffcanvas"
                        aria-controls="weeklyReflectionOffcanvas">
                    <i class="fa-regular fa-pen-to-square"></i> 週次の所感を入力
                </button>
            </div>
        }

        @* 週次の所感（タブ最上部・PDFでは1ページ目）。
           id を付けて Save 成功後に Partial で innerHTML 置換する。 *@
        <div id="weeklyReflectionContainer" data-reflection-period-type="Weekly" data-reflection-period-start="@weekStartIso">
            @await Html.PartialAsync("_PeriodReflectionDisplay", new Phycock.Views.Statistics.PeriodReflectionDisplayModel
            {
                Title = "週次の所感",
                Vm = weeklyReflection,
                ExtraClass = "period-reflection-page-break"
            })
        </div>

        <section class="weekly-report-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">週次レポート</h2>
                    <p class="text-muted small mb-0">体調、睡眠内訳、通所予定、メモを一週間で確認します。</p>
                </div>
                <span class="text-muted small">@weekStart.ToString("yyyy/MM/dd") 〜 @weekStart.AddDays(6).ToString("yyyy/MM/dd")</span>
            </div>

            <div class="weekly-report-chart">
                <canvas id="weeklyReportSampleChart"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（7-9時間）</span>
            </div>

            <div class="weekly-schedule-strip mt-3" aria-label="通所スケジュール">
                @foreach (var day in report.Days)
                {
                    <div class="schedule-day @day.ScheduleDayClass">
                        <span class="schedule-date">@day.Date.Month/@day.Date.Day</span>
                        @foreach (var s in day.ScheduleStrip)
                        {
                            <div class="schedule-entry @s.StatusClass">
                                <strong>@s.SessionLabel</strong>
                                @if (!string.IsNullOrEmpty(s.DetailLabel))
                                {
                                    <small>@s.DetailLabel</small>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="table-responsive mt-3 weekly-report-table-wrap">
                <table class="table table-sm align-middle weekly-report-table">
                    <thead>
                        <tr>
                            <th scope="col">日付</th>
                            <th scope="col">体調平均</th>
                            <th scope="col">気分平均</th>
                            <th scope="col">本睡眠</th>
                            <th scope="col">他睡眠</th>
                            <th scope="col">通所</th>
                            <th scope="col">体調記録の内訳（記録タイミング別）</th>
                            <th scope="col">睡眠記録メモ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in report.Days)
                        {
                            <tr>
                                <th scope="row">@d.DayLabel</th>
                                <td>@(d.ConditionAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.FeelingAvg?.ToString("0.0") ?? "-")</td>
                                <td>@(d.NightSleepHours > 0 ? $"{d.NightSleepHours:0.0}h" : "-")</td>
                                <td>@(d.OtherSleepHours > 0 ? $"{d.OtherSleepHours:0.0}h" : "-")</td>
                                <td>
                                    @* セッション単位で「予定 → 振り返り」の順に並べる（AM予定→AM振り返り→PM予定→PM振り返り） *@
                                    @if (d.ScheduleRows.Count == 0)
                                    {
                                        <div>予定なし</div>
                                    }
                                    @foreach (var row in d.ScheduleRows)
                                    {
                                        <div>@row.Summary</div>
                                        if (!string.IsNullOrEmpty(row.Reflection))
                                        {
                                            <div class="record-memo">@row.SessionLabel 振り返り: @row.Reflection</div>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (d.HealthRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var h in d.HealthRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@h.TimingLabel</strong>
                                            <span>
                                                体調 @h.ConditionLabel / 気分 @h.FeelingLabel / 症状: @h.SymptomsLabel
                                                @if (!string.IsNullOrEmpty(h.Memo))
                                                {
                                                    <span class="record-memo">メモ: @h.Memo</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (d.SleepRecords.Count == 0)
                                    {
                                        <span class="text-muted small">記録なし</span>
                                    }
                                    @foreach (var s in d.SleepRecords)
                                    {
                                        <div class="record-note">
                                            <strong>@s.TypeLabel</strong>
                                            <span>
                                                @($"{s.Hours:0.0}h")
                                                @if (!string.IsNullOrEmpty(s.Memo))
                                                {
                                                    <span class="record-memo">メモ: @s.Memo</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="weekly-timeline-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">睡眠時間帯 週次タイムライン</h2>
                    <p class="text-muted small mb-0">1日24時間軸で睡眠と通所予定の時間帯を一週間まとめて確認します。日跨ぎ睡眠は前後の日に分割表示。</p>
                </div>
            </div>

            <div class="weekly-timeline-chart">
                <canvas id="weeklyTimelineSampleChart"></canvas>
            </div>
            <div class="timeline-legend mt-2">
                <span class="legend-item"><span class="legend-swatch" style="background:#5B7CFA;"></span>本睡眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#8DD7BF;"></span>他睡眠 / 仮眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#F59F00;"></span>通所予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#198754;"></span>在宅予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch" style="background:@privateColor.Border;"></span>プライベート予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch legend-swatch-dashed"></span>通所予定 欠席（破線）</span>
                <span class="legend-item text-muted">※ 早退時は予定時間を短縮表示</span>
            </div>
        </section>
    </div>
    }
    @if (printMonthly)
    {
    <div class="@(isPrint ? "" : weeklyActive ? "tab-pane fade" : "tab-pane fade show active")" id="monthly" role="tabpanel">
        @{
            var monthlyRows = ReflectionRows(monthlyReflection);
            var monthlyHasInput = monthlyRows.Any(r => !string.IsNullOrWhiteSpace(r.Value));
        }
        @if (!isPrint)
        {
            <div class="d-flex justify-content-end mb-2">
                <button type="button" class="btn btn-outline-primary btn-sm"
                        data-bs-toggle="offcanvas" data-bs-target="#monthlyReflectionOffcanvas"
                        aria-controls="monthlyReflectionOffcanvas">
                    <i class="fa-regular fa-pen-to-square"></i> 月次の所感を入力
                </button>
            </div>
        }

        @* 月次の所感（タブ最上部・PDFでは1ページ目）。 *@
        <div id="monthlyReflectionContainer" data-reflection-period-type="Monthly" data-reflection-period-start="@monthStartIso">
            @await Html.PartialAsync("_PeriodReflectionDisplay", new Phycock.Views.Statistics.PeriodReflectionDisplayModel
            {
                Title = "月次の所感",
                Vm = monthlyReflection,
                ExtraClass = "period-reflection-page-break"
            })
        </div>

        <section class="monthly-calendar mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">月次カレンダー</h2>
                    <p class="text-muted small mb-0">体調、気分、睡眠合計、通所予定を日別に確認します。</p>
                </div>
                <span class="text-muted small">@monthlyCalendar.Year/@monthlyCalendar.Month.ToString("00")</span>
            </div>

            <div class="monthly-calendar-grid" role="table" aria-label="月次統計カレンダー">
                <div class="monthly-weekdays" role="row">
                    <div role="columnheader">日</div>
                    <div role="columnheader">月</div>
                    <div role="columnheader">火</div>
                    <div role="columnheader">水</div>
                    <div role="columnheader">木</div>
                    <div role="columnheader">金</div>
                    <div role="columnheader">土</div>
                </div>
                <div class="monthly-days" role="rowgroup">
                    @{ var weekIndex = 0; }
                    @foreach (var week in monthlyCalendar.Cells.Chunk(7))
                    {
                        // 3週ごとに改ページ（PDF出力時に週行が途中で切れないようにする）
                        var weekBreak = weekIndex > 0 && weekIndex % 3 == 0 ? " monthly-week-break" : "";
                        <div class="monthly-week@(weekBreak)" role="row">
                            @foreach (var cell in week)
                            {
                                var sleepClass = $"sleep-{cell.SleepLevel.ToString().ToLowerInvariant()}";
                                var scheduleClass = $"schedule-{cell.ScheduleDayClass}";
                                <div class="monthly-day @(cell.InMonth ? "" : "outside-month")" role="cell">
                                    <div class="monthly-day-number">@cell.Date.Day</div>
                                    @if (cell.InMonth)
                                    {
                                        <div class="monthly-metrics">
                                            <span class="monthly-metric @ScoreClass(cell.ConditionAvg)">
                                                <span>体調</span>
                                                <strong>@(cell.ConditionAvg?.ToString("0.0") ?? "-")</strong>
                                            </span>
                                            <span class="monthly-metric @ScoreClass(cell.FeelingAvg)">
                                                <span>気分</span>
                                                <strong>@(cell.FeelingAvg?.ToString("0.0") ?? "-")</strong>
                                            </span>
                                            <span class="monthly-metric @sleepClass">
                                                <span>睡眠</span>
                                                <strong>@($"{cell.SleepTotalHours:0.0}h")</strong>
                                            </span>
                                            <span class="monthly-schedule-chip @scheduleClass">@cell.ScheduleSummary</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        weekIndex++;
                    }
                </div>
            </div>

            <div class="monthly-legend mt-3" aria-label="凡例">
                <span class="legend-item"><span class="legend-swatch score-1"></span>体調・気分 1</span>
                <span class="legend-item"><span class="legend-swatch score-3"></span>体調・気分 3</span>
                <span class="legend-item"><span class="legend-swatch score-5"></span>体調・気分 5</span>
                <span class="legend-item"><span class="legend-swatch sleep-insufficient"></span>睡眠 &lt;6h</span>
                <span class="legend-item"><span class="legend-swatch sleep-slightlyshort"></span>睡眠 6-7h</span>
                <span class="legend-item"><span class="legend-swatch sleep-adequate"></span>睡眠 7-9h</span>
                <span class="legend-item"><span class="legend-swatch sleep-excessive"></span>睡眠 &gt;9h</span>
                <span class="legend-item"><span class="legend-swatch schedule-planned"></span>通所</span>
                <span class="legend-item"><span class="legend-swatch schedule-remote"></span>在宅</span>
                <span class="legend-item"><span class="legend-swatch schedule-private"></span>プライベート</span>
                <span class="legend-item"><span class="legend-swatch schedule-rest"></span>予定なし</span>
            </div>
        </section>

        <section class="monthly-chart">
            <h2 class="h5 mb-1">月次 体調・気分・睡眠</h2>
            <p class="text-muted small mb-3">体調・気分の推移と睡眠内訳を月単位で確認します。</p>
            <div class="monthly-report-chart">
                <canvas id="monthlyReportChart"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（7-9時間）</span>
            </div>
        </section>

        @* 帯別棒グラフ。月次PDF（print=1 &amp; section=monthly）では改ページ後に出力する *@
        <section class="sleep-correlation mt-4">
            <h2 class="h5 mb-1">前夜の睡眠時間と 翌日の体調</h2>
            <p class="text-muted small mb-3">前夜の睡眠を4つの帯に分け、その翌日の体調平均を比較します。</p>
            @if (monthlyCalendar.SleepConditionByBand.LeadText is null)
            {
                <p class="text-muted small mb-0">傾向を集計するにはデータが不足しています（体調記録と前夜の睡眠記録が揃った日が、複数の睡眠帯にまたがって必要です）。</p>
            }
            else
            {
                <div class="sleep-correlation-chart">
                    <canvas id="sleepConditionBandChart"></canvas>
                </div>
                <div class="correlation-lead mt-3">@monthlyCalendar.SleepConditionByBand.LeadText</div>
                <div class="table-responsive mt-3 sleep-correlation-table-wrap">
                    <table class="table table-sm align-middle sleep-correlation-table">
                        <thead>
                            <tr>
                                <th scope="col">睡眠帯</th>
                                <th scope="col">対象日数</th>
                                <th scope="col">前夜の睡眠記録（平均）</th>
                                <th scope="col">翌日の体調平均</th>
                                <th scope="col">翌日の通所スケジュール</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var band in monthlyCalendar.SleepConditionByBand.Bands)
                            {
                                <tr>
                                    <th scope="row">@band.Label</th>
                                    <td>@(band.DayCount > 0 ? $"{band.DayCount} 日" : "-")</td>
                                    <td>
                                        @if (band.DayCount > 0)
                                        {
                                            <text>本睡眠 @($"{band.AverageNightSleepHours:0.0}")h / 他睡眠 @($"{band.AverageOtherSleepHours:0.0}")h</text>
                                        }
                                        else
                                        {
                                            <text>-</text>
                                        }
                                    </td>
                                    <td>@(band.AverageCondition?.ToString("0.0") ?? "-")</td>
                                    <td>
                                        @if (band.DayCount > 0)
                                        {
                                            <text>通所 @band.AttendDayCount 日 / 在宅 @band.RemoteDayCount 日 / プライベート @band.PrivateDayCount 日 / 予定なし @band.RestDayCount 日</text>
                                        }
                                        else
                                        {
                                            <text>-</text>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="correlation-note mt-3">
                    ※ これは平均の比較であり、因果関係を保証するものではありません。日数の少ない帯は平均が不安定です。支援の判断材料の一つとしてご利用ください。
                </div>
            }
        </section>

    </div>
    }
</div>

@* 週次・月次の所感入力用フロート（offcanvas）。レポート閲覧中も裏で入力できる *@
@{
    (string OffcanvasId, string Title, Phycock.Models.PeriodReflectionViewModel Vm, string PeriodTypeName, string PeriodStartIso)[] offcanvasDefs = !isPrint
        ? new[]
        {
            ("weeklyReflectionOffcanvas",
                $"週次の所感（{weekStart:yyyy/MM/dd} 〜 {weekStart.AddDays(6):yyyy/MM/dd}）",
                weeklyReflection, "Weekly", weekStartIso),
            ("monthlyReflectionOffcanvas",
                $"月次の所感（{monthlyCalendar.Year}/{monthlyCalendar.Month:00}）",
                monthlyReflection, "Monthly", monthStartIso)
        }
        : Array.Empty<(string, string, Phycock.Models.PeriodReflectionViewModel, string, string)>();
}
@foreach (var d in offcanvasDefs)
{
    @* scroll=true: 背面のレポートをスクロール可能 / backdrop=false: 暗幕無しで両方見ながら入力できる *@
    <div class="offcanvas offcanvas-end" tabindex="-1" id="@d.OffcanvasId" aria-labelledby="@(d.OffcanvasId)Label"
         data-bs-scroll="true" data-bs-backdrop="false" style="width:480px; max-width:90vw;">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="@(d.OffcanvasId)Label">@d.Title</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="閉じる"></button>
        </div>
        <div class="offcanvas-body">
            @* 保存成功時に非同期で書き換える対象コンテナの id を data-target-container に持つ *@
            <form class="period-reflection-form" data-period-type="@d.PeriodTypeName" data-period-start="@d.PeriodStartIso"
                  data-target-container="@(d.PeriodTypeName == "Weekly" ? "weeklyReflectionContainer" : "monthlyReflectionContainer")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PeriodType" value="@d.PeriodTypeName" />
                <input type="hidden" name="PeriodStart" value="@d.PeriodStartIso" />
                <div class="alert alert-danger d-none reflection-error" role="alert"></div>
                <div class="alert alert-success d-none reflection-saved" role="alert">保存しました</div>

                <div class="mb-3">
                    <label class="form-label">自己評価</label>
                    <textarea name="SelfEvaluation" class="form-control" rows="3" maxlength="1000">@d.Vm.SelfEvaluation</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">負担</label>
                    <textarea name="Burden" class="form-control" rows="3" maxlength="1000">@d.Vm.Burden</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">改善案</label>
                    <textarea name="Improvement" class="form-control" rows="3" maxlength="1000">@d.Vm.Improvement</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">食欲</label>
                    <textarea name="Appetite" class="form-control" rows="3" maxlength="1000">@d.Vm.Appetite</textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">睡眠</label>
                    <textarea name="Sleep" class="form-control" rows="3" maxlength="1000">@d.Vm.Sleep</textarea>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">閉じる</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="reflection-submit-idle">保存</span>
                        <span class="reflection-submit-loading d-none">
                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                            保存中...
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        const isPrintMode = @(isPrint ? "true" : "false");
        const printSection = '@printSection';
        const currentWeekStart = '@weekStartIso';
        const currentMonthStart = '@monthStartIso';
        // サーバー側（DBデータ）から注入するチャート用データ
        const reportChartData = @Html.Raw(Json.Serialize(report.ReportChart));
        const timelineChartData = @Html.Raw(Json.Serialize(report.TimelineChart));
        const monthlyReportChartData = @Html.Raw(Json.Serialize(Model.MonthlyCalendar.ReportChart));
        const sleepConditionByBand = @Html.Raw(Json.Serialize(Model.MonthlyCalendar.SleepConditionByBand));
        const monthlyWeekStartOffset = @monthlyWeekStartOffset;
        let weeklyReportSampleChart;
        let monthlyReportChart;

        const sleepTargetBandPlugin = {
            id: 'sleepTargetBand',
            beforeDatasetsDraw(chart, args, pluginOptions) {
                const yScale = chart.scales.sleepHours;
                const { chartArea, ctx } = chart;
                if (!yScale || !chartArea || pluginOptions?.enabled === false) return;

                const from = pluginOptions?.from ?? 7;
                const to = pluginOptions?.to ?? 9;
                const yTop = yScale.getPixelForValue(to);
                const yBottom = yScale.getPixelForValue(from);

                ctx.save();
                ctx.fillStyle = pluginOptions?.color ?? 'rgba(255, 193, 7, 0.16)';
                ctx.fillRect(chartArea.left, yTop, chartArea.right - chartArea.left, yBottom - yTop);
                ctx.strokeStyle = pluginOptions?.borderColor ?? 'rgba(245, 159, 0, 0.45)';
                ctx.setLineDash([4, 4]);
                ctx.beginPath();
                ctx.moveTo(chartArea.left, yTop);
                ctx.lineTo(chartArea.right, yTop);
                ctx.moveTo(chartArea.left, yBottom);
                ctx.lineTo(chartArea.right, yBottom);
                ctx.stroke();
                ctx.restore();
            }
        };

        // 週次・月次共用の複合チャート設定（棒=睡眠内訳 / 折れ線=体調・気分）
        function reportChartConfig(chartData) {
            const sleepHoursAxisMax = 12;
            const data = {
                labels: chartData.labels,
                datasets: [
                    {
                        type: 'bar',
                        label: '本睡眠',
                        data: chartData.nightSleep,
                        backgroundColor: '#5B7CFA',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'bar',
                        label: '他睡眠',
                        data: chartData.otherSleep,
                        backgroundColor: '#8DD7BF',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'line',
                        label: '体調',
                        data: chartData.condition,
                        borderColor: '#E05D44',
                        backgroundColor: '#E05D44',
                        borderWidth: 3,
                        order: 1,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    },
                    {
                        type: 'line',
                        label: '気分',
                        data: chartData.feeling,
                        borderColor: '#F59F00',
                        backgroundColor: '#F59F00',
                        borderDash: [6, 3],
                        borderWidth: 3,
                        order: 0,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        spanGaps: true,
                        yAxisID: 'conditionScore'
                    }
                ]
            };
            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'bottom' },
                    sleepTargetBand: {
                        from: 7,
                        to: 9,
                        color: 'rgba(255, 193, 7, 0.16)',
                        borderColor: 'rgba(245, 159, 0, 0.45)'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const suffix = context.dataset.yAxisID === 'sleepHours' ? 'h' : '';
                                return `${context.dataset.label}: ${context.parsed.y}${suffix}`;
                            }
                        }
                    }
                },
                scales: {
                    x: { stacked: true },
                    sleepHours: {
                        type: 'linear',
                        position: 'left',
                        stacked: true,
                        min: 0,
                        max: sleepHoursAxisMax,
                        title: { display: true, text: '睡眠時間' }
                    },
                    conditionScore: {
                        type: 'linear',
                        position: 'right',
                        min: 1,
                        max: 5,
                        grid: { drawOnChartArea: false },
                        title: { display: true, text: '体調・気分' }
                    }
                }
            };

            return { data, options };
        }

        function createWeeklyReportSampleChart() {
            const { data, options } = reportChartConfig(reportChartData);
            if (weeklyReportSampleChart) {
                weeklyReportSampleChart.data = data;
                weeklyReportSampleChart.options = options;
                weeklyReportSampleChart.update();
                return;
            }

            weeklyReportSampleChart = new Chart(document.getElementById('weeklyReportSampleChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        function createMonthlyReportChart() {
            const { data, options } = reportChartConfig(monthlyReportChartData);
            // 一週間ごと（日曜起点）に縦線を引いて週の区切りを見やすくする
            const isWeekStart = (i) => i >= 0 && (i - monthlyWeekStartOffset) % 7 === 0;
            options.scales.x.grid = {
                display: true,
                color: (ctx) => isWeekStart(ctx.index) ? 'rgba(0,0,0,0.28)' : 'rgba(0,0,0,0.05)',
                lineWidth: (ctx) => isWeekStart(ctx.index) ? 1.5 : 1
            };
            monthlyReportChart = new Chart(document.getElementById('monthlyReportChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        // 前夜の睡眠帯ごとの「翌日の体調平均」棒グラフ（画面専用）
        function createSleepConditionBandChart() {
            const canvas = document.getElementById('sleepConditionBandChart');
            // データ不足の月は canvas 自体が描画されない
            if (!canvas) return;

            const bands = sleepConditionByBand.bands;
            // 帯は 不足 → やや不足 → 適正 → 過剰 の固定順。睡眠4段階の色と統一。
            const bandColors = [
                { bg: '#f8d7da', border: '#dc3545' },
                { bg: '#fff3cd', border: '#ffc107' },
                { bg: '#d1e7dd', border: '#198754' },
                { bg: '#cfe2ff', border: '#0d6efd' }
            ];

            new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: bands.map(b => b.label),
                    datasets: [{
                        label: '翌日の体調平均',
                        data: bands.map(b => b.averageCondition),
                        backgroundColor: bands.map((b, i) => bandColors[i].bg),
                        borderColor: bands.map((b, i) => bandColors[i].border),
                        borderWidth: 1.5,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: c => {
                                    const b = bands[c.dataIndex];
                                    return b.averageCondition === null
                                        ? 'データなし'
                                        : `翌日の体調平均 ${b.averageCondition.toFixed(1)}（対象 ${b.dayCount} 日）`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: { title: { display: true, text: '前夜の睡眠時間帯' } },
                        y: { title: { display: true, text: '翌日の体調平均スコア' }, min: 1, max: 5 }
                    }
                }
            });
        }

        let weeklyTimelineSampleChart;

        // Chart.js v4 の bar 枠線は塗りつぶしで描かれ borderDash が効かないため、
        // 欠席バーの破線枠だけプラグインでストローク描画する。
        const dashedAbsentBorderPlugin = {
            id: 'dashedAbsentBorder',
            afterDatasetsDraw(chart) {
                const ctx = chart.ctx;
                chart.data.datasets.forEach((ds, di) => {
                    if (ds.label !== '通所 欠席') return;
                    const meta = chart.getDatasetMeta(di);
                    if (meta.hidden) return;
                    ctx.save();
                    ctx.strokeStyle = '#F59F00';
                    ctx.lineWidth = 2;
                    ctx.setLineDash([6, 4]);
                    meta.data.forEach((bar, i) => {
                        if (!ds.data[i]) return;
                        const p = bar.getProps(['x', 'y', 'base', 'height'], true);
                        const left = Math.min(p.x, p.base);
                        const right = Math.max(p.x, p.base);
                        const top = p.y - p.height / 2;
                        ctx.strokeRect(left + 1, top + 1, (right - left) - 2, p.height - 2);
                    });
                    ctx.restore();
                });
            }
        };

        function createWeeklyTimelineSampleChart() {
            // 縦軸: 7日。横軸: 0-24h。データは [開始時刻, 終了時刻] の浮動バー。
            // null は当該日に該当無し。日跨ぎ睡眠は前後の日に分割済み（サーバー側で計算）。
            const labels = timelineChartData.labels;
            const nightSleepEarly = timelineChartData.nightSleepEarly;
            const nightSleepLate = timelineChartData.nightSleepLate;
            const otherSleepRaw = timelineChartData.otherSleep;
            const scheduleAm = timelineChartData.scheduleAm;
            const scheduleAbsent = timelineChartData.scheduleAbsent;
            const schedulePm = timelineChartData.schedulePm;
            const scheduleAmRemote = timelineChartData.scheduleAmRemote;
            const schedulePmRemote = timelineChartData.schedulePmRemote;
            const scheduleAmPrivate = timelineChartData.scheduleAmPrivate;
            const schedulePmPrivate = timelineChartData.schedulePmPrivate;

            const maxNaps = Math.max(...otherSleepRaw.map(d => d.length), 1);
            const otherSleepDatasets = [];
            for (let n = 0; n < maxNaps; n++) {
                otherSleepDatasets.push({
                    label: '他睡眠 / 仮眠',
                    data: otherSleepRaw.map(d => d.length > n ? d[n] : null),
                    backgroundColor: '#8DD7BF',
                    borderRadius: 4,
                    barPercentage: 0.95,
                    categoryPercentage: 0.95,
                    grouped: false
                });
            }

            function createScheduleDatasets(label, rawData, backgroundColor, borderColor, borderWidth = 1) {
                const maxEntries = Math.max(...rawData.map(d => d.length), 1);
                const datasets = [];
                for (let n = 0; n < maxEntries; n++) {
                    datasets.push({
                        label: label,
                        data: rawData.map(d => d.length > n ? d[n] : null),
                        backgroundColor: backgroundColor,
                        borderColor: borderColor,
                        borderWidth: borderWidth,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    });
                }
                return datasets;
            }

            const data = {
                labels: labels,
                datasets: [
                    {
                        label: '本睡眠',
                        data: nightSleepEarly,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '本睡眠（夜）',
                        data: nightSleepLate,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    ...otherSleepDatasets,
                    ...createScheduleDatasets('通所 AM', scheduleAm, 'rgba(245, 159, 0, 0.85)', '#F59F00'),
                    ...createScheduleDatasets('通所 PM', schedulePm, 'rgba(245, 159, 0, 0.85)', '#F59F00'),
                    ...createScheduleDatasets('在宅 AM', scheduleAmRemote, 'rgba(25, 135, 84, 0.85)', '#198754'),
                    ...createScheduleDatasets('在宅 PM', schedulePmRemote, 'rgba(25, 135, 84, 0.85)', '#198754'),
                    ...createScheduleDatasets('プライベート AM', scheduleAmPrivate, '@privateColor.Border', '@privateColor.Border'),
                    ...createScheduleDatasets('プライベート PM', schedulePmPrivate, '@privateColor.Border', '@privateColor.Border'),
                    ...createScheduleDatasets('通所 欠席', scheduleAbsent, 'rgba(245, 159, 0, 0.10)', '#F59F00', 0)
                ]
            };

            const formatHour = (v) => {
                const h = Math.floor(v);
                const m = Math.round((v - h) * 60);
                return m === 0 ? `${h}:00` : `${h}:${String(m).padStart(2, '0')}`;
            };

            const options = {
                responsive: true,
                maintainAspectRatio: false,
                animation: isPrintMode ? false : undefined,
                layout: { padding: { right: 8, left: 4, top: 4, bottom: 4 } },
                indexAxis: 'y',
                interaction: { mode: 'nearest', intersect: true },
                plugins: {
                    legend: {
                        display: false  // 凡例は HTML 側で表示（本睡眠2バーの重複を避ける）
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const v = context.raw;
                                if (!v) return '';
                                return `${context.dataset.label}: ${formatHour(v[0])} - ${formatHour(v[1])}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        position: 'bottom',
                        min: 0,
                        max: 24,
                        title: { display: true, text: '時刻 (0:00 - 24:00)' },
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: {
                            color: (ctx) => ctx.tick && ctx.tick.value % 3 === 0
                                ? 'rgba(0,0,0,0.18)'
                                : 'rgba(0,0,0,0.07)',
                            lineWidth: 1
                        }
                    },
                    xTop: {
                        type: 'linear',
                        position: 'top',
                        min: 0,
                        max: 24,
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: { display: false }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 13 } }
                    }
                }
            };

            if (weeklyTimelineSampleChart) {
                weeklyTimelineSampleChart.data = data;
                weeklyTimelineSampleChart.options = options;
                weeklyTimelineSampleChart.update();
                return;
            }

            weeklyTimelineSampleChart = new Chart(
                document.getElementById('weeklyTimelineSampleChart'),
                { type: 'bar', data: data, options: options, plugins: [dashedAbsentBorderPlugin] }
            );
        }

        if (isPrintMode) {
            // ポイント: print=1 のときはサーバー側 Playwright が描画完了を window.chartsReady で検知する
            // section に応じて描画するチャートを切り替える（不在の canvas を触らない）
            if (printSection === 'monthly') {
                createMonthlyReportChart();
                createSleepConditionBandChart();
            } else {
                createWeeklyReportSampleChart();
                createWeeklyTimelineSampleChart();
            }
            // requestAnimationFrame 2回でレイアウト確定 → chartsReady を立てる
            requestAnimationFrame(() => requestAnimationFrame(() => {
                window.chartsReady = true;
            }));
        } else {
            $('#weekStart').val(currentWeekStart);
            // 「更新」: 週次レポートはサーバー再取得が必要なのでページ遷移する。
            // 現在表示中のタブ（週次/月次）を維持するため tab クエリを付与する。
            // 月次タブで日付を変えた場合は、その日付を含む月の月初へ正規化してから遷移し、
            // 結果として月次タブのまま該当月のカレンダーが表示されるようにする。
            $('#reloadStats').on('click', function () {
                const ws = $('#weekStart').val();
                const activeTab = document.querySelector('.nav-tabs .nav-link.active');
                const tab = activeTab?.dataset.bsTarget === '#monthly' ? 'monthly' : 'weekly';
                // 月次タブのときは選択日付を月初に正規化して送る（月単位で再描画させる）
                let wsParam = ws;
                if (tab === 'monthly' && ws) {
                    const d = new Date(ws + 'T00:00:00');
                    if (!isNaN(d.getTime())) {
                        const y = d.getFullYear();
                        const m = String(d.getMonth() + 1).padStart(2, '0');
                        wsParam = `${y}-${m}-01`;
                    }
                }
                window.location.href = '@Url.Action("Index", "Statistics")'
                    + '?weekStart=' + encodeURIComponent(wsParam) + '&tab=' + tab;
            });
            document.getElementById('prevWeek')?.addEventListener('click', function () {
                const activeTab = document.querySelector('.nav-tabs .nav-link.active');
                const isMonthly = activeTab?.dataset.bsTarget === '#monthly';
                const current = isMonthly ? currentMonthStart : document.getElementById('weekStart').value;
                if (!current) return;
                const d = new Date(current + 'T00:00:00');
                if (isMonthly) {
                    d.setMonth(d.getMonth() - 1);
                } else {
                    d.setDate(d.getDate() - 7);
                }
                const y = d.getFullYear();
                const m = String(d.getMonth() + 1).padStart(2, '0');
                const day = String(d.getDate()).padStart(2, '0');
                document.getElementById('weekStart').value = `${y}-${m}-${day}`;
                document.getElementById('reloadStats').click();
            });

            document.getElementById('nextWeek')?.addEventListener('click', function () {
                const activeTab = document.querySelector('.nav-tabs .nav-link.active');
                const isMonthly = activeTab?.dataset.bsTarget === '#monthly';
                const current = isMonthly ? currentMonthStart : document.getElementById('weekStart').value;
                if (!current) return;
                const d = new Date(current + 'T00:00:00');
                if (isMonthly) {
                    d.setMonth(d.getMonth() + 1);
                } else {
                    d.setDate(d.getDate() + 7);
                }
                const y = d.getFullYear();
                const m = String(d.getMonth() + 1).padStart(2, '0');
                const day = String(d.getDate()).padStart(2, '0');
                document.getElementById('weekStart').value = `${y}-${m}-${day}`;
                document.getElementById('reloadStats').click();
            });

            // PDF出力: アクティブなタブ（週次/月次）に応じて出力対象を切り替える
            $('#exportPdf').on('click', async function () {
                const button = this;
                if (button.disabled) {
                    return;
                }

                const ws = $('#weekStart').val();
                const activeTab = document.querySelector('.nav-tabs .nav-link.active');
                const section = activeTab?.dataset.bsTarget === '#monthly' ? 'monthly' : 'weekly';
                const url = '@Url.Action("ExportPdf", "Statistics")'
                    + '?weekStart=' + encodeURIComponent(ws) + '&section=' + section;

                const setLoading = (isLoading) => {
                    button.disabled = isLoading;
                    button.setAttribute('aria-busy', isLoading ? 'true' : 'false');
                    button.querySelector('.pdf-export-idle')?.classList.toggle('d-none', isLoading);
                    button.querySelector('.pdf-export-loading')?.classList.toggle('d-none', !isLoading);
                };

                const getDownloadFileName = (response) => {
                    const disposition = response.headers.get('content-disposition') ?? '';
                    const utf8Match = disposition.match(/filename\*=UTF-8''([^;]+)/i);
                    if (utf8Match) {
                        return decodeURIComponent(utf8Match[1]);
                    }

                    const asciiMatch = disposition.match(/filename="?([^";]+)"?/i);
                    return asciiMatch ? asciiMatch[1] : 'Phycock_statistics.pdf';
                };

                setLoading(true);
                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        credentials: 'same-origin',
                        headers: { 'Accept': 'application/pdf' }
                    });

                    if (!response.ok) {
                        const message = await response.text();
                        throw new Error(message || 'PDF出力に失敗しました。しばらく時間をおいてから再度お試しください。');
                    }

                    const contentType = response.headers.get('content-type') ?? '';
                    if (!contentType.toLowerCase().includes('application/pdf')) {
                        throw new Error('PDFを取得できませんでした。ログイン状態を確認してから再度お試しください。');
                    }

                    const blob = await response.blob();
                    const downloadUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = downloadUrl;
                    link.download = getDownloadFileName(response);
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(downloadUrl);
                } catch (error) {
                    alert(error instanceof Error ? error.message : 'PDF出力に失敗しました。しばらく時間をおいてから再度お試しください。');
                } finally {
                    setLoading(false);
                }
            });
            // タブ切替時にボタンタイトルを更新（週次=前週/次週、月次=前月/次月）
            document.querySelectorAll('.nav-tabs .nav-link').forEach(function (tabBtn) {
                tabBtn.addEventListener('shown.bs.tab', function () {
                    const isMonthly = tabBtn.dataset.bsTarget === '#monthly';
                    document.getElementById('prevWeek').title = isMonthly ? '前月' : '前週';
                    document.getElementById('nextWeek').title = isMonthly ? '次月' : '次週';
                });
            });
            // 初期表示が月次タブの場合もタイトルを設定
            if (document.querySelector('.nav-tabs .nav-link.active')?.dataset.bsTarget === '#monthly') {
                document.getElementById('prevWeek').title = '前月';
                document.getElementById('nextWeek').title = '次月';
            }

            createWeeklyReportSampleChart();
            createWeeklyTimelineSampleChart();
            createMonthlyReportChart();
            createSleepConditionBandChart();

            // ───────────── 期間所感（週次・月次）の保存処理 ─────────────
            // offcanvas 内の form を Ajax 送信する。成功時は location.reload で
            // レポート本体に所感を即時反映する（既存PDF/JSと干渉しない最小実装）。
            document.querySelectorAll('.period-reflection-form').forEach(function (form) {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    const errorBox = form.querySelector('.reflection-error');
                    const savedBox = form.querySelector('.reflection-saved');
                    const submitBtn = form.querySelector('button[type="submit"]');
                    const idleLabel = form.querySelector('.reflection-submit-idle');
                    const loadingLabel = form.querySelector('.reflection-submit-loading');
                    errorBox.classList.add('d-none');
                    savedBox.classList.add('d-none');
                    submitBtn.disabled = true;
                    idleLabel.classList.add('d-none');
                    loadingLabel.classList.remove('d-none');

                    try {
                        const formData = new FormData(form);
                        const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
                        const res = await fetch('@Url.Action("Save", "PeriodReflection")', {
                            method: 'POST',
                            body: formData,
                            headers: { 'X-CSRF-TOKEN': token },
                            credentials: 'same-origin'
                        });
                        if (!res.ok) {
                            let msg = '保存に失敗しました。';
                            try {
                                const json = await res.json();
                                if (json.errors) {
                                    const all = Object.values(json.errors).flat();
                                    if (all.length > 0) msg = all.join(' / ');
                                } else if (json.error) {
                                    msg = json.error;
                                }
                            } catch { /* fallthrough */ }
                            errorBox.textContent = msg;
                            errorBox.classList.remove('d-none');
                            return;
                        }
                        savedBox.classList.remove('d-none');
                        // 非同期で所感表示パーシャルを取り直し、現在開いているタブを切り替えずに
                        // 該当コンテナの中身だけ差し替える（タブ状態・スクロール位置を保持）。
                        try {
                            const periodType = form.dataset.periodType;
                            const periodStart = form.dataset.periodStart;
                            const partialUrl = `@Url.Action("GetPartial", "PeriodReflection")?periodType=${encodeURIComponent(periodType)}&periodStart=${encodeURIComponent(periodStart)}`;
                            const partRes = await fetch(partialUrl, { credentials: 'same-origin' });
                            if (partRes.ok) {
                                const html = await partRes.text();
                                const containerId = form.dataset.targetContainer;
                                const container = document.getElementById(containerId);
                                if (container) container.innerHTML = html;
                            }
                        } catch { /* 表示更新失敗は無視（次回再表示で同期される） */ }
                        // 数秒で「保存しました」を消す
                        setTimeout(function () { savedBox.classList.add('d-none'); }, 2000);
                    } catch (err) {
                        errorBox.textContent = '通信エラーが発生しました。';
                        errorBox.classList.remove('d-none');
                    } finally {
                        submitBtn.disabled = false;
                        idleLabel.classList.remove('d-none');
                        loadingLabel.classList.add('d-none');
                    }
                });
            });
        }
    </script>
}

