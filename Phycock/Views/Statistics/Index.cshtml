@{
    ViewData["Title"] = "統計";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h1 class="h3 mb-0">統計</h1>
    <div class="d-flex gap-2">
        <input id="weekStart" type="date" class="form-control" />
        <button id="reloadStats" type="button" class="btn btn-outline-primary">更新</button>
        <button id="exportSamplePdf" type="button" class="btn btn-outline-secondary">
            <i class="fa-regular fa-file-pdf"></i> PDF出力（サンプル）
        </button>
    </div>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#weekly" type="button" role="tab">週次</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">月次</button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="weekly" role="tabpanel">
        <section class="weekly-report-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">週次レポートサンプル</h2>
                    <p class="text-muted small mb-0">体調、睡眠内訳、通所予定、メモを一週間で確認する表示案です。</p>
                </div>
                <span class="badge text-bg-light border">サンプルデータ</span>
            </div>

            <div class="weekly-report-chart">
                <canvas id="weeklyReportSampleChart" height="150"></canvas>
            </div>
            <div class="chart-guide mt-2">
                <span class="sleep-target-swatch"></span>
                <span>背景の黄色帯: 正常な睡眠時間の目安（6-8時間）</span>
            </div>

            <div class="weekly-schedule-strip mt-3" aria-label="通所スケジュール">
                <div class="schedule-day planned">
                    <span class="schedule-date">5/4</span>
                    <div class="schedule-entry status-attended">
                        <strong>AM 通所</strong>
                        <small>通所済み / ヘルスケア</small>
                    </div>
                    <div class="schedule-entry status-attended">
                        <strong>PM 通所</strong>
                        <small>通所済み / 個別訓練</small>
                    </div>
                </div>
                <div class="schedule-day remote">
                    <span class="schedule-date">5/5</span>
                    <div class="schedule-entry status-planned">
                        <strong>PM 在宅</strong>
                        <small>予定 / セルフワーク</small>
                    </div>
                </div>
                <div class="schedule-day planned">
                    <span class="schedule-date">5/6</span>
                    <div class="schedule-entry status-late">
                        <strong>AM 通所</strong>
                        <small>遅刻 / 職場コミュニケーション</small>
                    </div>
                    <div class="schedule-entry status-attended">
                        <strong>PM 通所</strong>
                        <small>通所済み / 部署活動</small>
                    </div>
                </div>
                <div class="schedule-day rest">
                    <span class="schedule-date">5/7</span>
                    <div class="schedule-entry status-absent">
                        <strong>AM 通所</strong>
                        <small>欠席 / 体調不良</small>
                    </div>
                </div>
                <div class="schedule-day planned">
                    <span class="schedule-date">5/8</span>
                    <div class="schedule-entry status-early-leave">
                        <strong>AM 通所</strong>
                        <small>早退 / 就労前の準備</small>
                    </div>
                </div>
                <div class="schedule-day rest">
                    <span class="schedule-date">5/9</span>
                    <div class="schedule-entry status-none">
                        <strong>予定なし</strong>
                        <small>休養日</small>
                    </div>
                </div>
                <div class="schedule-day rest">
                    <span class="schedule-date">5/10</span>
                    <div class="schedule-entry status-none">
                        <strong>予定なし</strong>
                        <small>翌週準備</small>
                    </div>
                </div>
            </div>

            <div class="table-responsive mt-3">
                <table class="table table-sm align-middle weekly-report-table">
                    <thead>
                        <tr>
                            <th scope="col">日付</th>
                            <th scope="col">体調平均</th>
                            <th scope="col">気分平均</th>
                            <th scope="col">本睡眠</th>
                            <th scope="col">他睡眠</th>
                            <th scope="col">通所</th>
                            <th scope="col">体調記録の内訳（記録タイミング別）</th>
                            <th scope="col">睡眠記録メモ</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th scope="row">5/4 月</th>
                            <td>4.0</td>
                            <td>3.8</td>
                            <td>6.5h</td>
                            <td>0.5h</td>
                            <td>AM 通所済み / PM 通所済み</td>
                            <td>
                                <div class="record-note"><strong>起床時</strong><span>体調 3 / 気分 3 / 症状: 眠気<span class="record-memo">メモ: 起床直後は重い。</span></span></div>
                                <div class="record-note"><strong>訓練開始時</strong><span>体調 4 / 気分 4 / 症状: なし<span class="record-memo">メモ: 午後から集中できた。</span></span></div>
                                <div class="record-note"><strong>就眠時</strong><span>体調 5 / 気分 4 / 症状: なし<span class="record-memo">メモ: 帰宅後も安定。</span></span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>6.5h / 途中で一度起きたが再入眠できた。</span></div>
                                <div class="record-note"><strong>他睡眠</strong><span>0.5h / 通所後に短く休んだ。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/5 火</th>
                            <td>3.2</td>
                            <td>3.0</td>
                            <td>5.0h</td>
                            <td>1.5h</td>
                            <td>PM 在宅予定</td>
                            <td>
                                <div class="record-note"><strong>起床時</strong><span>体調 3 / 気分 2 / 症状: 頭痛、不安<span class="record-memo">メモ: 朝から緊張が強い。</span></span></div>
                                <div class="record-note"><strong>就眠時</strong><span>体調 3.5 / 気分 4 / 症状: 眠気<span class="record-memo">メモ: 在宅後は落ち着いた。</span></span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>5.0h / 夜間に中途覚醒。</span></div>
                                <div class="record-note"><strong>他睡眠</strong><span>1.5h / 昼寝で補った。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/6 水</th>
                            <td>3.8</td>
                            <td>3.4</td>
                            <td>6.0h</td>
                            <td>1.0h</td>
                            <td>AM 遅刻 / PM 通所済み</td>
                            <td>
                                <div class="record-note"><strong>起床時</strong><span>体調 3 / 気分 3 / 症状: 不安、倦怠感<span class="record-memo">メモ: 遅刻連絡済み。</span></span></div>
                                <div class="record-note"><strong>訓練開始時</strong><span>体調 4 / 気分 3.5 / 症状: 不安<span class="record-memo">メモ: 作業量を調整。</span></span></div>
                                <div class="record-note"><strong>訓練終了時</strong><span>体調 4.5 / 気分 4 / 症状: なし</span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>6.0h / 入眠に時間がかかった。</span></div>
                                <div class="record-note"><strong>他睡眠</strong><span>1.0h / 帰宅後に仮眠。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/7 木</th>
                            <td>2.8</td>
                            <td>2.6</td>
                            <td>4.5h</td>
                            <td>2.0h</td>
                            <td>AM 欠席</td>
                            <td>
                                <div class="record-note"><strong>起床時</strong><span>体調 2.5 / 気分 2 / 症状: 眠気、頭痛<span class="record-memo">メモ: 体調不良で休養。</span></span></div>
                                <div class="record-note"><strong>就眠時</strong><span>体調 3 / 気分 3.2 / 症状: 眠気<span class="record-memo">メモ: 少し回復。</span></span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>4.5h / 夜の睡眠が短い。</span></div>
                                <div class="record-note"><strong>他睡眠</strong><span>2.0h / 昼寝が長め。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/8 金</th>
                            <td>4.4</td>
                            <td>4.2</td>
                            <td>7.0h</td>
                            <td>0.5h</td>
                            <td>AM 早退</td>
                            <td>
                                <div class="record-note"><strong>起床時</strong><span>体調 4.5 / 気分 4 / 症状: なし<span class="record-memo">メモ: 体調は安定。</span></span></div>
                                <div class="record-note"><strong>訓練終了時</strong><span>体調 4.3 / 気分 4.4 / 症状: 軽い倦怠感</span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>7.0h / 本睡眠が取れて起床後も安定。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/9 土</th>
                            <td>4.1</td>
                            <td>4.0</td>
                            <td>7.5h</td>
                            <td>0h</td>
                            <td>予定なし</td>
                            <td>
                                <div class="record-note"><strong>訓練開始時</strong><span>体調 4.1 / 気分 4 / 症状: なし</span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>本睡眠</strong><span>7.5h / まとまって眠れた。</span></div>
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">5/10 日</th>
                            <td>3.6</td>
                            <td>3.4</td>
                            <td>6.0h</td>
                            <td>1.0h</td>
                            <td>予定なし</td>
                            <td>
                                <div class="record-note"><strong>就眠時</strong><span>体調 3.6 / 気分 3.4 / 症状: 不安<span class="record-memo">メモ: 翌週の通所準備で緊張あり。</span></span></div>
                            </td>
                            <td>
                                <div class="record-note"><strong>他睡眠</strong><span>1.0h / 夕方に短い仮眠。</span></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="weekly-timeline-sample mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">睡眠時間帯 週次タイムライン（サンプル）</h2>
                    <p class="text-muted small mb-0">1日24時間軸で睡眠と通所予定の時間帯を一週間まとめて確認します。日跨ぎ睡眠は前後の日に分割表示。</p>
                </div>
                <span class="badge text-bg-light border">サンプルデータ</span>
            </div>

            <div class="weekly-timeline-chart">
                <canvas id="weeklyTimelineSampleChart" height="220"></canvas>
            </div>
            <div class="timeline-legend mt-2">
                <span class="legend-item"><span class="legend-swatch" style="background:#5B7CFA;"></span>本睡眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#8DD7BF;"></span>他睡眠 / 仮眠</span>
                <span class="legend-item"><span class="legend-swatch" style="background:#F59F00;"></span>通所予定（AM / PM）</span>
                <span class="legend-item"><span class="legend-swatch legend-swatch-dashed"></span>通所予定 欠席（破線）</span>
                <span class="legend-item text-muted">※ 早退時は予定時間を短縮表示</span>
            </div>
        </section>

        <div class="row">
            <div class="col-lg-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">体調・気分</h5>
                        <canvas id="weeklyHealthChart" height="160"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">睡眠時間</h5>
                        <canvas id="weeklySleepChart" height="160"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="tab-pane fade" id="monthly" role="tabpanel">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">月次 体調・気分</h5>
                <canvas id="monthlyHealthChart" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        let weeklyHealthChart;
        let weeklySleepChart;
        let monthlyHealthChart;
        let weeklyReportSampleChart;
        const statisticsUrls = {
            healthWeekly: '@Url.Action("GetHealthWeekly", "Statistics")',
            sleepWeekly: '@Url.Action("GetSleepWeekly", "Statistics")',
            healthMonthly: '@Url.Action("GetHealthMonthly", "Statistics")'
        };

        function toDateInputValue(date) {
            return date.toISOString().slice(0, 10);
        }

        function createOrUpdateLineChart(chart, canvasId, labels, conditionData, feelingData) {
            const data = {
                labels: labels,
                datasets: [
                    { label: '体調', data: conditionData, borderColor: '#0d6efd', backgroundColor: '#0d6efd', tension: 0.25 },
                    { label: '気分', data: feelingData, borderColor: '#F59F00', backgroundColor: '#F59F00', tension: 0.25 }
                ]
            };
            if (chart) {
                chart.data = data;
                chart.update();
                return chart;
            }
            return new Chart(document.getElementById(canvasId), { type: 'line', data: data });
        }

        function createOrUpdateBarChart(chart, canvasId, labels, sleepHoursData) {
            const data = {
                labels: labels,
                datasets: [{ label: '睡眠時間', data: sleepHoursData, backgroundColor: '#6f42c1' }]
            };
            if (chart) {
                chart.data = data;
                chart.update();
                return chart;
            }
            return new Chart(document.getElementById(canvasId), { type: 'bar', data: data });
        }

        const sleepTargetBandPlugin = {
            id: 'sleepTargetBand',
            beforeDatasetsDraw(chart, args, pluginOptions) {
                const yScale = chart.scales.sleepHours;
                const { chartArea, ctx } = chart;
                if (!yScale || !chartArea || pluginOptions?.enabled === false) return;

                const from = pluginOptions?.from ?? 6;
                const to = pluginOptions?.to ?? 8;
                const yTop = yScale.getPixelForValue(to);
                const yBottom = yScale.getPixelForValue(from);

                ctx.save();
                ctx.fillStyle = pluginOptions?.color ?? 'rgba(255, 193, 7, 0.16)';
                ctx.fillRect(chartArea.left, yTop, chartArea.right - chartArea.left, yBottom - yTop);
                ctx.strokeStyle = pluginOptions?.borderColor ?? 'rgba(245, 159, 0, 0.45)';
                ctx.setLineDash([4, 4]);
                ctx.beginPath();
                ctx.moveTo(chartArea.left, yTop);
                ctx.lineTo(chartArea.right, yTop);
                ctx.moveTo(chartArea.left, yBottom);
                ctx.lineTo(chartArea.right, yBottom);
                ctx.stroke();
                ctx.restore();
            }
        };

        function createWeeklyReportSampleChart() {
            const labels = ['5/4', '5/5', '5/6', '5/7', '5/8', '5/9', '5/10'];
            const data = {
                labels: labels,
                datasets: [
                    {
                        type: 'bar',
                        label: '本睡眠',
                        data: [6.5, 5.0, 6.0, 4.5, 7.0, 7.5, 6.0],
                        backgroundColor: '#5B7CFA',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'bar',
                        label: '他睡眠',
                        data: [0.5, 1.5, 1.0, 2.0, 0.5, 0, 1.0],
                        backgroundColor: '#8DD7BF',
                        order: 3,
                        borderRadius: 4,
                        stack: 'sleep',
                        yAxisID: 'sleepHours'
                    },
                    {
                        type: 'line',
                        label: '体調',
                        data: [4.0, 3.2, 3.8, 2.8, 4.4, 4.1, 3.6],
                        borderColor: '#E05D44',
                        backgroundColor: '#E05D44',
                        borderWidth: 3,
                        order: 1,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        yAxisID: 'conditionScore'
                    },
                    {
                        type: 'line',
                        label: '気分',
                        data: [3.8, 3.0, 3.4, 2.6, 4.2, 4.0, 3.4],
                        borderColor: '#F59F00',
                        backgroundColor: '#F59F00',
                        borderDash: [6, 3],
                        borderWidth: 3,
                        order: 0,
                        tension: 0.25,
                        pointRadius: 5,
                        pointHoverRadius: 6,
                        yAxisID: 'conditionScore'
                    }
                ]
            };
            const options = {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'bottom' },
                    sleepTargetBand: {
                        from: 6,
                        to: 8,
                        color: 'rgba(255, 193, 7, 0.16)',
                        borderColor: 'rgba(245, 159, 0, 0.45)'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const suffix = context.dataset.yAxisID === 'sleepHours' ? 'h' : '';
                                return `${context.dataset.label}: ${context.parsed.y}${suffix}`;
                            }
                        }
                    }
                },
                scales: {
                    x: { stacked: true },
                    sleepHours: {
                        type: 'linear',
                        position: 'left',
                        stacked: true,
                        min: 0,
                        max: 10,
                        title: { display: true, text: '睡眠時間' }
                    },
                    conditionScore: {
                        type: 'linear',
                        position: 'right',
                        min: 1,
                        max: 5,
                        grid: { drawOnChartArea: false },
                        title: { display: true, text: '体調・気分' }
                    }
                }
            };

            if (weeklyReportSampleChart) {
                weeklyReportSampleChart.data = data;
                weeklyReportSampleChart.options = options;
                weeklyReportSampleChart.update();
                return;
            }

            weeklyReportSampleChart = new Chart(document.getElementById('weeklyReportSampleChart'), {
                data: data,
                options: options,
                plugins: [sleepTargetBandPlugin]
            });
        }

        function loadStats() {
            const weekStart = $('#weekStart').val();
            const date = new Date(weekStart + 'T00:00:00');
            $.get(statisticsUrls.healthWeekly, { weekStart: weekStart }, function (data) {
                weeklyHealthChart = createOrUpdateLineChart(
                    weeklyHealthChart,
                    'weeklyHealthChart',
                    data.labels,
                    data.conditionData,
                    data.feelingData);
            });
            $.get(statisticsUrls.sleepWeekly, { weekStart: weekStart }, function (data) {
                weeklySleepChart = createOrUpdateBarChart(
                    weeklySleepChart,
                    'weeklySleepChart',
                    data.labels,
                    data.sleepHoursData);
            });
            $.get(statisticsUrls.healthMonthly, { year: date.getFullYear(), month: date.getMonth() + 1 }, function (data) {
                monthlyHealthChart = createOrUpdateLineChart(
                    monthlyHealthChart,
                    'monthlyHealthChart',
                    data.labels,
                    data.conditionData,
                    data.feelingData);
            });
        }

        let weeklyTimelineSampleChart;

        function createWeeklyTimelineSampleChart() {
            // 縦軸: 7日（上から月→日）。横軸: 0-24h。
            // データは [開始時刻, 終了時刻] の浮動バー。null は当該日に該当無し。
            // 日跨ぎ睡眠は「前日 [23.x, 24]」「当日 [0, 起床時刻]」の 2 バーに分割。
            const labels = ['5/4 (月)', '5/5 (火)', '5/6 (水)', '5/7 (木)', '5/8 (金)', '5/9 (土)', '5/10 (日)'];

            const nightSleepEarly = [
                [0, 7.0],   // 月: 前夜から 7:00 まで
                [0, 6.5],   // 火
                [0, 6.0],   // 水
                [0, 5.5],   // 木: 浅い
                [0, 7.5],   // 金
                [0, 7.5],   // 土
                [0, 6.0]    // 日
            ];
            const nightSleepLate = [
                [23.5, 24], // 月の夜（→翌火曜 0 時へ続く）
                [23.0, 24], // 火
                [23.0, 24], // 水
                [22.5, 24], // 木
                [23.5, 24], // 金
                [23.0, 24], // 土
                null         // 日: 翌週開始のため省略
            ];
            const otherSleep = [
                null,
                [14.0, 15.0], // 火: 仮眠
                null,
                [13.0, 14.5], // 木: 体調不良で日中休息
                null,
                null,
                [17.0, 18.0]  // 日: 夕方の短い仮眠
            ];
            const scheduleAm = [
                [9.5, 12.5],  // 月
                null,           // 火: 予定なし
                [9.5, 12.5],  // 水
                null,           // 木: 欠席 → scheduleAbsent へ
                [9.5, 12.5],  // 金
                null,           // 土
                null            // 日
            ];
            const scheduleAbsent = [
                null,
                null,
                null,
                [9.5, 12.5],  // 木: AM 欠席（破線表示）
                null,
                null,
                null
            ];
            const schedulePm = [
                [13.5, 15.5],
                [13.5, 15.5], // 火: 在宅 PM
                [13.5, 15.5],
                null,
                [13.5, 14.5], // 金: 早退で短く
                null,
                null
            ];

            const data = {
                labels: labels,
                datasets: [
                    {
                        label: '本睡眠',
                        data: nightSleepEarly,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '本睡眠（夜）',
                        data: nightSleepLate,
                        backgroundColor: '#5B7CFA',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '他睡眠 / 仮眠',
                        data: otherSleep,
                        backgroundColor: '#8DD7BF',
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 AM',
                        data: scheduleAm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 PM',
                        data: schedulePm,
                        backgroundColor: 'rgba(245, 159, 0, 0.85)',
                        borderColor: '#F59F00',
                        borderWidth: 1,
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    },
                    {
                        label: '通所 欠席',
                        data: scheduleAbsent,
                        backgroundColor: 'rgba(245, 159, 0, 0.10)',
                        borderColor: '#F59F00',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        borderRadius: 4,
                        barPercentage: 0.95,
                        categoryPercentage: 0.95,
                        grouped: false
                    }
                ]
            };

            const formatHour = (v) => {
                const h = Math.floor(v);
                const m = Math.round((v - h) * 60);
                return m === 0 ? `${h}:00` : `${h}:${String(m).padStart(2, '0')}`;
            };

            const options = {
                responsive: true,
                indexAxis: 'y',
                interaction: { mode: 'nearest', intersect: true },
                plugins: {
                    legend: {
                        display: false  // 凡例は HTML 側で表示（本睡眠2バーの重複を避ける）
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const v = context.raw;
                                if (!v) return '';
                                return `${context.dataset.label}: ${formatHour(v[0])} - ${formatHour(v[1])}`;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        position: 'bottom',
                        min: 0,
                        max: 24,
                        title: { display: true, text: '時刻 (0:00 - 24:00)' },
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: {
                            color: (ctx) => ctx.tick && ctx.tick.value % 3 === 0
                                ? 'rgba(0,0,0,0.18)'
                                : 'rgba(0,0,0,0.07)',
                            lineWidth: 1
                        }
                    },
                    xTop: {
                        type: 'linear',
                        position: 'top',
                        min: 0,
                        max: 24,
                        ticks: {
                            stepSize: 1,
                            autoSkip: false,
                            callback: (v) => `${v}`
                        },
                        grid: { display: false }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 13 } }
                    }
                }
            };

            if (weeklyTimelineSampleChart) {
                weeklyTimelineSampleChart.data = data;
                weeklyTimelineSampleChart.options = options;
                weeklyTimelineSampleChart.update();
                return;
            }

            weeklyTimelineSampleChart = new Chart(
                document.getElementById('weeklyTimelineSampleChart'),
                { type: 'bar', data: data, options: options }
            );
        }

        const today = new Date();
        const weekStart = new Date(today);
        weekStart.setDate(today.getDate() - today.getDay());
        $('#weekStart').val(toDateInputValue(weekStart));
        $('#reloadStats').on('click', loadStats);
        createWeeklyReportSampleChart();
        createWeeklyTimelineSampleChart();
        loadStats();
    </script>
    <script src="~/js/statistics-pdf-sample.js" asp-append-version="true"></script>
}

